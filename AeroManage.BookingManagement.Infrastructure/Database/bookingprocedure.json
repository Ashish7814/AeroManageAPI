IF NOT EXISTS (SELECT * FROM sys.tables WHERE name = 'PromoCodes')
BEGIN
    CREATE TABLE PromoCodes (
        PromoCodeId INT IDENTITY(1,1) PRIMARY KEY,
        Code NVARCHAR(50) UNIQUE NOT NULL,
        DiscountType NVARCHAR(20) NOT NULL, -- Percentage, Fixed
        DiscountValue DECIMAL(10, 2) NOT NULL,
        MinimumAmount DECIMAL(10, 2) NULL,
        MaximumDiscount DECIMAL(10, 2) NULL,
        UsageLimit INT NULL,
        UsageCount INT DEFAULT 0,
        ValidFrom DATETIME NOT NULL,
        ValidUntil DATETIME NOT NULL,
        IsActive BIT DEFAULT 1,
        CreatedAt DATETIME DEFAULT GETDATE(),
        CONSTRAINT CHK_PromoCodes_DiscountType CHECK (DiscountType IN ('Percentage', 'Fixed')),
        CONSTRAINT CHK_PromoCodes_DiscountValue CHECK (DiscountValue > 0)
    );
END
GO

