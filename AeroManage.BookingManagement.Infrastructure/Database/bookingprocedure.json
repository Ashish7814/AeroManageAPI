-- =============================================
-- SP: Search Flights (Multi-city support)
-- =============================================
CREATE OR ALTER PROCEDURE sp_SearchFlights
    @OriginAirportId INT = NULL,
    @DestinationAirportId INT = NULL,
    @DepartureDate DATE = NULL,
    @ReturnDate DATE = NULL,
    @PassengerCount INT = 1,
    @SeatClass NVARCHAR(20) = 'Economy',
    @MaxPrice DECIMAL(10,2) = NULL,
    @MaxStops INT = NULL,
    @AirlineId INT = NULL,
    @PageNumber INT = 1,
    @PageSize INT = 20
AS
BEGIN
    SET NOCOUNT ON;
    
    DECLARE @Offset INT = (@PageNumber - 1) * @PageSize;
    
    WITH FlightResults AS (
        SELECT 
            f.FlightId,
            f.FlightNumber,
            f.FlightStatus,
            f.DepartureDateTime,
            f.ArrivalDateTime,
            f.DepartureGate,
            f.ArrivalGate,
            r.RouteId,
            r.RouteCode,
            r.Distance,
            r.EstimatedDuration,
            -- Origin
            oa.AirportId AS OriginAirportId,
            oa.AirportCode AS OriginCode,
            oa.AirportName AS OriginName,
            oa.City AS OriginCity,
            oa.Country AS OriginCountry,
            -- Destination
            da.AirportId AS DestinationAirportId,
            da.AirportCode AS DestinationCode,
            da.AirportName AS DestinationName,
            da.City AS DestinationCity,
            da.Country AS DestinationCountry,
            -- Aircraft
            ac.AircraftId,
            ac.RegistrationNumber,
            ac.Model AS AircraftModel,
            -- Pricing
            CASE @SeatClass
                WHEN 'Economy' THEN f.EconomyPrice
                WHEN 'Business' THEN f.BusinessPrice
                WHEN 'FirstClass' THEN f.FirstClassPrice
                ELSE f.EconomyPrice
            END AS Price,
            -- Seat Availability
            (SELECT COUNT(*) FROM Seats s 
             WHERE s.AircraftId = ac.AircraftId AND s.SeatClass = @SeatClass AND s.IsAvailable = 1
             AND NOT EXISTS (
                SELECT 1 FROM SeatReservations sr 
                WHERE sr.SeatId = s.SeatId AND sr.FlightId = f.FlightId 
                AND sr.ReservationStatus = 'Confirmed'
             )) AS AvailableSeats,
            -- Layovers count
            (SELECT COUNT(*) FROM RouteLayovers rl WHERE rl.RouteId = r.RouteId) AS Stops
        FROM Flights f
        INNER JOIN Routes r ON f.RouteId = r.RouteId
        INNER JOIN Airports oa ON r.OriginAirportId = oa.AirportId
        INNER JOIN Airports da ON r.DestinationAirportId = da.AirportId
        LEFT JOIN Aircraft ac ON f.AircraftId = ac.AircraftId
        WHERE f.FlightStatus IN ('Scheduled', 'Boarding')
            AND (@OriginAirportId IS NULL OR r.OriginAirportId = @OriginAirportId)
            AND (@DestinationAirportId IS NULL OR r.DestinationAirportId = @DestinationAirportId)
            AND (@DepartureDate IS NULL OR CAST(f.DepartureDateTime AS DATE) = @DepartureDate)
    )
    SELECT *,
        (SELECT COUNT(*) FROM FlightResults) AS TotalRecords
    FROM FlightResults
    WHERE (@MaxPrice IS NULL OR Price <= @MaxPrice)
        AND (@MaxStops IS NULL OR Stops <= @MaxStops)
        AND AvailableSeats >= @PassengerCount
    ORDER BY Price ASC, DepartureDateTime ASC
    OFFSET @Offset ROWS
    FETCH NEXT @PageSize ROWS ONLY;
END
GO

-- =============================================
-- SP: Generate Booking Reference
-- =============================================
CREATE OR ALTER PROCEDURE sp_GenerateBookingReference
AS
BEGIN
    SET NOCOUNT ON;
    
    DECLARE @Reference NVARCHAR(10);
    DECLARE @Exists INT = 1;
    
    WHILE @Exists = 1
    BEGIN
        -- Generate 6-character alphanumeric code
        SET @Reference = 
            CHAR(65 + ABS(CHECKSUM(NEWID())) % 26) +
            CHAR(65 + ABS(CHECKSUM(NEWID())) % 26) +
            CHAR(65 + ABS(CHECKSUM(NEWID())) % 26) +
            CAST(ABS(CHECKSUM(NEWID())) % 10 AS NVARCHAR) +
            CAST(ABS(CHECKSUM(NEWID())) % 10 AS NVARCHAR) +
            CAST(ABS(CHECKSUM(NEWID())) % 10 AS NVARCHAR);
        
        -- Check if exists
        IF NOT EXISTS (SELECT 1 FROM Bookings WHERE BookingReference = @Reference)
            SET @Exists = 0;
    END
    
    SELECT @Reference AS BookingReference;
END
GO

-- =============================================
-- SP: Generate PNR
-- =============================================
CREATE OR ALTER PROCEDURE sp_GeneratePNR
AS
BEGIN
    SET NOCOUNT ON;
    
    DECLARE @PNR NVARCHAR(6);
    DECLARE @Exists INT = 1;
    
    WHILE @Exists = 1
    BEGIN
        -- Generate 6-character alphanumeric PNR
        SET @PNR = 
            CHAR(65 + ABS(CHECKSUM(NEWID())) % 26) +
            CHAR(65 + ABS(CHECKSUM(NEWID())) % 26) +
            CAST(ABS(CHECKSUM(NEWID())) % 10 AS NVARCHAR) +
            CAST(ABS(CHECKSUM(NEWID())) % 10 AS NVARCHAR) +
            CHAR(65 + ABS(CHECKSUM(NEWID())) % 26) +
            CHAR(65 + ABS(CHECKSUM(NEWID())) % 26);
        
        IF NOT EXISTS (SELECT 1 FROM Bookings WHERE PNR = @PNR)
            SET @Exists = 0;
    END
    
    SELECT @PNR AS PNR;
END
GO

-- =============================================
-- SP: Create Booking
-- =============================================
CREATE OR ALTER PROCEDURE sp_CreateBooking
    @BookingReference NVARCHAR(10),
    @PNR NVARCHAR(6),
    @UserId INT = NULL,
    @TotalAmount DECIMAL(10,2),
    @Currency NVARCHAR(3) = 'USD',
    @BookingEmail NVARCHAR(255),
    @BookingPhone NVARCHAR(20) = NULL,
    @SpecialRequests NVARCHAR(1000) = NULL,
    @CreatedBy INT = NULL
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRANSACTION;
    BEGIN TRY
        INSERT INTO Bookings (
            BookingReference, PNR, UserId, TotalAmount, Currency,
            BookingEmail, BookingPhone, SpecialRequests, CreatedBy
        )
        VALUES (
            @BookingReference, @PNR, @UserId, @TotalAmount, @Currency,
            @BookingEmail, @BookingPhone, @SpecialRequests, @CreatedBy
        );
        
        DECLARE @BookingId INT = SCOPE_IDENTITY();
        
        -- Audit log
        INSERT INTO BookingHistory (BookingId, Action, NewValue, ChangedBy)
        VALUES (@BookingId, 'Created', '{"Status":"Pending"}', @CreatedBy);
        
        -- Return created booking
        SELECT 
            BookingId, BookingReference, PNR, UserId, BookingStatus,
            TotalAmount, Currency, PaymentStatus, BookingDate,
            BookingEmail, BookingPhone
        FROM Bookings
        WHERE BookingId = @BookingId;
        
        COMMIT TRANSACTION;
    END TRY
    BEGIN CATCH
        ROLLBACK TRANSACTION;
        THROW;
    END CATCH
END
GO

-- =============================================
-- SP: Add Passenger to Booking
-- =============================================
CREATE OR ALTER PROCEDURE sp_AddPassengerToBooking
    @BookingId INT,
    @PassengerId INT,
    @PassengerType NVARCHAR(20),
    @SeatClass NVARCHAR(20),
    @MealPreference NVARCHAR(50) = NULL,
    @SpecialAssistance NVARCHAR(500) = NULL,
    @ExtraBaggage INT = 0
AS
BEGIN
    SET NOCOUNT ON;
    
    INSERT INTO BookingPassengers (
        BookingId, PassengerId, PassengerType, SeatClass,
        MealPreference, SpecialAssistance, ExtraBaggage
    )
    VALUES (
        @BookingId, @PassengerId, @PassengerType, @SeatClass,
        @MealPreference, @SpecialAssistance, @ExtraBaggage
    );
    
    SELECT 
        BookingPassengerId, BookingId, PassengerId,
        PassengerType, SeatClass, MealPreference
    FROM BookingPassengers
    WHERE BookingPassengerId = SCOPE_IDENTITY();
END
GO

-- =============================================
-- SP: Reserve Seat
-- =============================================
CREATE OR ALTER PROCEDURE sp_ReserveSeat
    @FlightId INT,
    @SeatId INT,
    @BookingPassengerId INT,
    @HoldMinutes INT = 15
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRANSACTION;
    BEGIN TRY
        -- Check if seat is available
        IF EXISTS (
            SELECT 1 FROM SeatReservations 
            WHERE FlightId = @FlightId AND SeatId = @SeatId 
            AND ReservationStatus = 'Confirmed'
        )
        BEGIN
            ROLLBACK TRANSACTION;
            THROW 50001, 'Seat already reserved', 1;
        END
        
        -- Reserve seat
        INSERT INTO SeatReservations (FlightId, SeatId, BookingPassengerId, ReservationStatus, ExpiresAt)
        VALUES (@FlightId, @SeatId, @BookingPassengerId, 'Reserved', DATEADD(MINUTE, @HoldMinutes, GETDATE()));
        
        -- Update seat number in booking
        UPDATE BookingPassengers
        SET SeatNumber = (SELECT SeatNumber FROM Seats WHERE SeatId = @SeatId)
        WHERE BookingPassengerId = @BookingPassengerId;
        
        COMMIT TRANSACTION;
        
        SELECT ReservationId, FlightId, SeatId, ReservationStatus, ExpiresAt
        FROM SeatReservations
        WHERE ReservationId = SCOPE_IDENTITY();
    END TRY
    BEGIN CATCH
        ROLLBACK TRANSACTION;
        THROW;
    END CATCH
END
GO

-- =============================================
-- SP: Confirm Booking (After Payment)
-- =============================================
CREATE OR ALTER PROCEDURE sp_ConfirmBooking
    @BookingId INT,
    @PaymentIntentId NVARCHAR(255)
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRANSACTION;
    BEGIN TRY
        -- Update booking status
        UPDATE Bookings
        SET BookingStatus = 'Confirmed',
            PaymentStatus = 'Paid',
            PaymentIntentId = @PaymentIntentId,
            UpdatedAt = GETDATE()
        WHERE BookingId = @BookingId;
        
        -- Confirm all seat reservations
        UPDATE sr
        SET ReservationStatus = 'Confirmed',
            ExpiresAt = NULL
        FROM SeatReservations sr
        INNER JOIN BookingPassengers bp ON sr.BookingPassengerId = bp.BookingPassengerId
        WHERE bp.BookingId = @BookingId;
        
        -- Audit log
        INSERT INTO BookingHistory (BookingId, Action, NewValue)
        VALUES (@BookingId, 'Confirmed', '{"Status":"Confirmed","Payment":"' + @PaymentIntentId + '"}');
        
        COMMIT TRANSACTION;
        
        -- Return booking details
        SELECT 
            b.BookingId, b.BookingReference, b.PNR, b.BookingStatus,
            b.PaymentStatus, b.TotalAmount, b.Currency, b.BookingEmail
        FROM Bookings b
        WHERE b.BookingId = @BookingId;
    END TRY
    BEGIN CATCH
        ROLLBACK TRANSACTION;
        THROW;
    END CATCH
END
GO

-- =============================================
-- SP: Get Booking Details
-- =============================================
CREATE OR ALTER PROCEDURE sp_GetBookingDetails
    @BookingId INT = NULL,
    @BookingReference NVARCHAR(10) = NULL,
    @PNR NVARCHAR(6) = NULL
AS
BEGIN
    SET NOCOUNT ON;
    
    -- Booking details
    SELECT 
        b.BookingId, b.BookingReference, b.PNR, b.UserId, b.BookingStatus,
        b.TotalAmount, b.Currency, b.PaymentStatus, b.PaymentMethod,
        b.BookingDate, b.BookingEmail, b.BookingPhone, b.SpecialRequests
    FROM Bookings b
    WHERE (@BookingId IS NOT NULL AND b.BookingId = @BookingId)
       OR (@BookingReference IS NOT NULL AND b.BookingReference = @BookingReference)
       OR (@PNR IS NOT NULL AND b.PNR = @PNR);
    
    -- Flights
    SELECT 
        bf.BookingFlightId, bf.FlightSegment,
        f.FlightId, f.FlightNumber, f.DepartureDateTime, f.ArrivalDateTime,
        r.RouteCode, oa.AirportCode AS OriginCode, da.AirportCode AS DestinationCode
    FROM BookingFlights bf
    INNER JOIN Flights f ON bf.FlightId = f.FlightId
    INNER JOIN Routes r ON f.RouteId = r.RouteId
    INNER JOIN Airports oa ON r.OriginAirportId = oa.AirportId
    INNER JOIN Airports da ON r.DestinationAirportId = da.AirportId
    WHERE bf.BookingId = (
        SELECT BookingId FROM Bookings 
        WHERE (@BookingId IS NOT NULL AND BookingId = @BookingId)
           OR (@BookingReference IS NOT NULL AND BookingReference = @BookingReference)
           OR (@PNR IS NOT NULL AND PNR = @PNR)
    );
    
    -- Passengers
    SELECT 
        bp.BookingPassengerId, bp.PassengerType, bp.SeatClass,
        bp.SeatNumber, bp.MealPreference, bp.TicketNumber,
        p.PassengerId, p.FirstName, p.LastName, p.Email, p.Phone
    FROM BookingPassengers bp
    INNER JOIN Passengers p ON bp.PassengerId = p.PassengerId
    WHERE bp.BookingId = (
        SELECT BookingId FROM Bookings 
        WHERE (@BookingId IS NOT NULL AND BookingId = @BookingId)
           OR (@BookingReference IS NOT NULL AND BookingReference = @BookingReference)
           OR (@PNR IS NOT NULL AND PNR = @PNR)
    );
END
GO

-- =============================================
-- SP: Cancel Booking
-- =============================================
CREATE OR ALTER PROCEDURE sp_CancelBooking
    @BookingId INT,
    @CancelledBy INT,
    @RefundAmount DECIMAL(10,2) = NULL
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRANSACTION;
    BEGIN TRY
        -- Check if already cancelled
        IF EXISTS (SELECT 1 FROM Bookings WHERE BookingId = @BookingId AND BookingStatus = 'Cancelled')
        BEGIN
            ROLLBACK TRANSACTION;
            THROW 50002, 'Booking already cancelled', 1;
        END
        
        -- Update booking
        UPDATE Bookings
        SET BookingStatus = 'Cancelled',
            UpdatedAt = GETDATE()
        WHERE BookingId = @BookingId;
        
        -- Release seats
        UPDATE SeatReservations
        SET ReservationStatus = 'Cancelled'
        WHERE BookingPassengerId IN (
            SELECT BookingPassengerId FROM BookingPassengers WHERE BookingId = @BookingId
        );
        
        -- Audit log
        INSERT INTO BookingHistory (BookingId, Action, NewValue, ChangedBy)
        VALUES (@BookingId, 'Cancelled', '{"RefundAmount":"' + CAST(@RefundAmount AS NVARCHAR) + '"}', @CancelledBy);
        
        COMMIT TRANSACTION;
        
        SELECT BookingId, BookingReference, BookingStatus
        FROM Bookings
        WHERE BookingId = @BookingId;
    END TRY
    BEGIN CATCH
        ROLLBACK TRANSACTION;
        THROW;
    END CATCH
END
GO

-- =============================================
-- SP: Get User Bookings
-- =============================================
CREATE OR ALTER PROCEDURE sp_GetUserBookings
    @UserId INT,
    @PageNumber INT = 1,
    @PageSize INT = 10
AS
BEGIN
    SET NOCOUNT ON;
    
    DECLARE @Offset INT = (@PageNumber - 1) * @PageSize;
    
    SELECT 
        b.BookingId, b.BookingReference, b.PNR, b.BookingStatus,
        b.TotalAmount, b.Currency, b.BookingDate,
        COUNT(DISTINCT bp.BookingPassengerId) AS PassengerCount,
        COUNT(DISTINCT bf.FlightId) AS FlightCount,
        (SELECT COUNT(*) FROM Bookings WHERE UserId = @UserId) AS TotalRecords
    FROM Bookings b
    LEFT JOIN BookingPassengers bp ON b.BookingId = bp.BookingId
    LEFT JOIN BookingFlights bf ON b.BookingId = bf.BookingId
    WHERE b.UserId = @UserId AND b.IsDeleted = 0
    GROUP BY b.BookingId, b.BookingReference, b.PNR, b.BookingStatus,
             b.TotalAmount, b.Currency, b.BookingDate
    ORDER BY b.BookingDate DESC
    OFFSET @Offset ROWS
    FETCH NEXT @PageSize ROWS ONLY;
END
GO

-- =============================================
-- SP: Validate Promo Code
-- =============================================
CREATE OR ALTER PROCEDURE sp_ValidatePromoCode
    @Code NVARCHAR(50),
    @BookingAmount DECIMAL(10,2)
AS
BEGIN
    SET NOCOUNT ON;
    
    SELECT 
        PromoCodeId, Code, Description, DiscountType,
        DiscountValue, MinimumAmount, MaximumDiscount,
        ValidFrom, ValidTo, UsageLimit, UsedCount,
        CASE 
            WHEN IsActive = 0 THEN 'Promo code is inactive'
            WHEN GETDATE() < ValidFrom THEN 'Promo code not yet valid'
            WHEN GETDATE() > ValidTo THEN 'Promo code has expired'
            WHEN @BookingAmount < MinimumAmount THEN 'Minimum booking amount not met'
            WHEN UsageLimit > 0 AND UsedCount >= UsageLimit THEN 'Promo code usage limit reached'
            ELSE 'Valid'
        END AS ValidationStatus,
        CASE 
            WHEN DiscountType = 'Percentage' THEN 
                CASE 
                    WHEN MaximumDiscount IS NOT NULL AND (@BookingAmount * DiscountValue / 100) > MaximumDiscount 
                    THEN MaximumDiscount
                    ELSE @BookingAmount * DiscountValue / 100
                END
            WHEN DiscountType = 'Fixed' THEN DiscountValue
            ELSE 0
        END AS CalculatedDiscount
    FROM PromoCodes
    WHERE Code = @Code;
END
GO

