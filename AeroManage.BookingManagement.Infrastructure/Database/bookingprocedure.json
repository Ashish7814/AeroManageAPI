-- =============================================
-- SP: Validate Promo Code
-- =============================================
CREATE OR ALTER PROCEDURE sp_ValidatePromoCode
    @Code NVARCHAR(50),
    @BookingAmount DECIMAL(10, 2)
AS
BEGIN
    SET NOCOUNT ON;
    
    DECLARE @PromoCodeId INT;
    DECLARE @DiscountType NVARCHAR(20);
    DECLARE @DiscountValue DECIMAL(10, 2);
    DECLARE @MinimumAmount DECIMAL(10, 2);
    DECLARE @MaximumDiscount DECIMAL(10, 2);
    DECLARE @UsageLimit INT;
    DECLARE @UsageCount INT;
    DECLARE @ValidFrom DATETIME;
    DECLARE @ValidUntil DATETIME;
    DECLARE @IsActive BIT;
    DECLARE @ValidationStatus NVARCHAR(100);
    DECLARE @CalculatedDiscount DECIMAL(10, 2) = 0;
    
    -- Get promo code details
    SELECT 
        @PromoCodeId = PromoCodeId,
        @DiscountType = DiscountType,
        @DiscountValue = DiscountValue,
        @MinimumAmount = MinimumAmount,
        @MaximumDiscount = MaximumDiscount,
        @UsageLimit = UsageLimit,
        @UsageCount = UsageCount,
        @ValidFrom = ValidFrom,
        @ValidUntil = ValidUntil,
        @IsActive = IsActive
    FROM PromoCodes
    WHERE Code = @Code;
    
    -- Check if promo code exists
    IF @PromoCodeId IS NULL
    BEGIN
        SET @ValidationStatus = 'Invalid promo code';
    END
    -- Check if active
    ELSE IF @IsActive = 0
    BEGIN
        SET @ValidationStatus = 'Promo code is inactive';
    END
    -- Check if within valid date range
    ELSE IF GETDATE() < @ValidFrom
    BEGIN
        SET @ValidationStatus = 'Promo code not yet valid';
    END
    ELSE IF GETDATE() > @ValidUntil
    BEGIN
        SET @ValidationStatus = 'Promo code has expired';
    END
    -- Check usage limit
    ELSE IF @UsageLimit IS NOT NULL AND @UsageCount >= @UsageLimit
    BEGIN
        SET @ValidationStatus = 'Promo code usage limit reached';
    END
    -- Check minimum amount
    ELSE IF @MinimumAmount IS NOT NULL AND @BookingAmount < @MinimumAmount
    BEGIN
        SET @ValidationStatus = 'Booking amount does not meet minimum requirement of $' + CAST(@MinimumAmount AS NVARCHAR);
    END
    ELSE
    BEGIN
        SET @ValidationStatus = 'Valid';
        
        -- Calculate discount
        IF @DiscountType = 'Percentage'
        BEGIN
            SET @CalculatedDiscount = @BookingAmount * (@DiscountValue / 100);
            
            -- Apply maximum discount if specified
            IF @MaximumDiscount IS NOT NULL AND @CalculatedDiscount > @MaximumDiscount
                SET @CalculatedDiscount = @MaximumDiscount;
        END
        ELSE IF @DiscountType = 'Fixed'
        BEGIN
            SET @CalculatedDiscount = @DiscountValue;
            
            -- Don't exceed booking amount
            IF @CalculatedDiscount > @BookingAmount
                SET @CalculatedDiscount = @BookingAmount;
        END
    END
    
    -- Return result
    SELECT 
        PromoCodeId,
        Code,
        DiscountType,
        DiscountValue,
        MinimumAmount,
        MaximumDiscount,
        UsageLimit,
        UsageCount,
        ValidFrom,
        ValidUntil,
        IsActive,
        @ValidationStatus AS ValidationStatus,
        @CalculatedDiscount AS CalculatedDiscount
    FROM PromoCodes
    WHERE Code = @Code;
END
GO

-- =============================================
-- SP: Increment Promo Code Usage
-- =============================================
CREATE OR ALTER PROCEDURE sp_IncrementPromoCodeUsage
    @PromoCodeId INT
AS
BEGIN
    SET NOCOUNT ON;
    
    UPDATE PromoCodes
    SET UsageCount = UsageCount + 1
    WHERE PromoCodeId = @PromoCodeId;
    
    SELECT 1 AS Success;
END
GO

-- =============================================
-- SP: Get Active Promo Codes
-- =============================================
CREATE OR ALTER PROCEDURE sp_GetActivePromoCodes
AS
BEGIN
    SET NOCOUNT ON;
    
    SELECT 
        PromoCodeId,
        Code,
        DiscountType,
        DiscountValue,
        MinimumAmount,
        MaximumDiscount,
        UsageLimit,
        UsageCount,
        ValidFrom,
        ValidUntil,
        IsActive,
        CreatedAt
    FROM PromoCodes
    WHERE IsActive = 1
        AND GETDATE() BETWEEN ValidFrom AND ValidUntil
        AND (UsageLimit IS NULL OR UsageCount < UsageLimit)
    ORDER BY CreatedAt DESC;
END
GO

-- =============================================
-- SP: Create Promo Code
-- =============================================
CREATE OR ALTER PROCEDURE sp_CreatePromoCode
    @Code NVARCHAR(50),
    @DiscountType NVARCHAR(20),
    @DiscountValue DECIMAL(10, 2),
    @MinimumAmount DECIMAL(10, 2) = NULL,
    @MaximumDiscount DECIMAL(10, 2) = NULL,
    @UsageLimit INT = NULL,
    @ValidFrom DATETIME,
    @ValidUntil DATETIME
AS
BEGIN
    SET NOCOUNT ON;
    
    -- Check if code already exists
    IF EXISTS (SELECT 1 FROM PromoCodes WHERE Code = @Code)
    BEGIN
        RAISERROR('Promo code already exists', 16, 1);
        RETURN;
    END
    
    INSERT INTO PromoCodes (
        Code, DiscountType, DiscountValue, MinimumAmount, MaximumDiscount,
        UsageLimit, ValidFrom, ValidUntil, IsActive
    )
    VALUES (
        @Code, @DiscountType, @DiscountValue, @MinimumAmount, @MaximumDiscount,
        @UsageLimit, @ValidFrom, @ValidUntil, 1
    );
    
    SELECT SCOPE_IDENTITY() AS PromoCodeId;
END
GO

-- =============================================
-- SP: Update Promo Code
-- =============================================
CREATE OR ALTER PROCEDURE sp_UpdatePromoCode
    @PromoCodeId INT,
    @DiscountType NVARCHAR(20) = NULL,
    @DiscountValue DECIMAL(10, 2) = NULL,
    @MinimumAmount DECIMAL(10, 2) = NULL,
    @MaximumDiscount DECIMAL(10, 2) = NULL,
    @UsageLimit INT = NULL,
    @ValidFrom DATETIME = NULL,
    @ValidUntil DATETIME = NULL,
    @IsActive BIT = NULL
AS
BEGIN
    SET NOCOUNT ON;
    
    UPDATE PromoCodes
    SET DiscountType = ISNULL(@DiscountType, DiscountType),
        DiscountValue = ISNULL(@DiscountValue, DiscountValue),
        MinimumAmount = ISNULL(@MinimumAmount, MinimumAmount),
        MaximumDiscount = ISNULL(@MaximumDiscount, MaximumDiscount),
        UsageLimit = ISNULL(@UsageLimit, UsageLimit),
        ValidFrom = ISNULL(@ValidFrom, ValidFrom),
        ValidUntil = ISNULL(@ValidUntil, ValidUntil),
        IsActive = ISNULL(@IsActive, IsActive)
    WHERE PromoCodeId = @PromoCodeId;
    
    SELECT 1 AS Success;
END
GO

-- =============================================
-- SP: Deactivate Promo Code
-- =============================================
CREATE OR ALTER PROCEDURE sp_DeactivatePromoCode
    @PromoCodeId INT
AS
BEGIN
    SET NOCOUNT ON;
    
    UPDATE PromoCodes
    SET IsActive = 0
    WHERE PromoCodeId = @PromoCodeId;
    
    SELECT 1 AS Success;
END
GO

