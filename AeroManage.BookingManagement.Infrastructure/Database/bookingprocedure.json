-- ───────────────────────────────────────────────────────────
-- sp_GetBookingHistory
-- Retrieves paginated booking history with filters
-- ───────────────────────────────────────────────────────────

CREATE OR ALTER PROCEDURE sp_GetBookingHistory
    @UserId         INT = NULL,
    @BookingReference VARCHAR(10) = NULL,
    @PNR            VARCHAR(6) = NULL,
    @Status         VARCHAR(20) = NULL,
    @FromDate       DATETIME = NULL,
    @ToDate         DATETIME = NULL,
    @Page           INT = 1,
    @PageSize       INT = 10,
    @TotalCount     INT OUTPUT
AS
BEGIN
    SET NOCOUNT ON;

    DECLARE @Offset INT = (@Page - 1) * @PageSize;

    -- Get total count
    SELECT @TotalCount = COUNT(*)
    FROM Bookings b
    WHERE (@UserId IS NULL OR b.UserId = @UserId)
      AND (@BookingReference IS NULL OR b.BookingReference = @BookingReference)
      AND (@PNR IS NULL OR b.PNR = @PNR)
      AND (@Status IS NULL OR b.BookingStatus = @Status)
      AND (@FromDate IS NULL OR b.CreatedAt >= @FromDate)
      AND (@ToDate IS NULL OR b.CreatedAt <= @ToDate);

    -- Get paginated results
    SELECT 
        b.BookingId,
        b.BookingReference,
        b.PNR,
        b.BookingStatus,
        b.CreatedAt AS BookingDate,
        (SELECT MIN(f.DepartureDateTime) 
         FROM BookingFlights bf 
         INNER JOIN Flights f ON bf.FlightId = f.FlightId 
         WHERE bf.BookingId = b.BookingId) AS TravelDate,
        (SELECT COUNT(*) FROM Passengers WHERE BookingId = b.BookingId) AS PassengerCount,
        (SELECT COUNT(*) FROM BookingFlights WHERE BookingId = b.BookingId) AS FlightCount,
        bp.TotalAmount,
        bp.Currency,
        p.PaymentStatus,
        b.UpdatedAt AS LastModified
    FROM Bookings b
    LEFT JOIN BookingPricings bp ON b.BookingId = bp.BookingId
    LEFT JOIN Payments p ON b.BookingId = p.BookingId
    WHERE (@UserId IS NULL OR b.UserId = @UserId)
      AND (@BookingReference IS NULL OR b.BookingReference = @BookingReference)
      AND (@PNR IS NULL OR b.PNR = @PNR)
      AND (@Status IS NULL OR b.BookingStatus = @Status)
      AND (@FromDate IS NULL OR b.CreatedAt >= @FromDate)
      AND (@ToDate IS NULL OR b.CreatedAt <= @ToDate)
    ORDER BY b.CreatedAt DESC
    OFFSET @Offset ROWS
    FETCH NEXT @PageSize ROWS ONLY;
END;
GO

-- ───────────────────────────────────────────────────────────
-- sp_GetBookingStatistics
-- Retrieves comprehensive booking analytics
-- ───────────────────────────────────────────────────────────

CREATE OR ALTER PROCEDURE sp_GetBookingStatistics
    @UserId   INT = NULL,
    @FromDate DATETIME = NULL,
    @ToDate   DATETIME = NULL
AS
BEGIN
    SET NOCOUNT ON;

    DECLARE @Stats TABLE (
        TotalBookings      INT,
        ActiveBookings     INT,
        CancelledBookings  INT,
        CompletedBookings  INT,
        TotalRevenue       DECIMAL(18,2),
        AverageBookingValue DECIMAL(18,2),
        TotalPassengers    INT
    );

    -- Calculate main statistics
    INSERT INTO @Stats
    SELECT 
        COUNT(DISTINCT b.BookingId) AS TotalBookings,
        SUM(CASE WHEN b.BookingStatus IN ('Confirmed','Pending') THEN 1 ELSE 0 END) AS ActiveBookings,
        SUM(CASE WHEN b.BookingStatus = 'Cancelled' THEN 1 ELSE 0 END) AS CancelledBookings,
        SUM(CASE WHEN b.BookingStatus = 'Completed' THEN 1 ELSE 0 END) AS CompletedBookings,
        ISNULL(SUM(bp.TotalAmount), 0) AS TotalRevenue,
        ISNULL(AVG(bp.TotalAmount), 0) AS AverageBookingValue,
        SUM((SELECT COUNT(*) FROM Passengers p WHERE p.BookingId = b.BookingId)) AS TotalPassengers
    FROM Bookings b
    LEFT JOIN BookingPricings bp ON b.BookingId = bp.BookingId
    WHERE (@UserId IS NULL OR b.UserId = @UserId)
      AND (@FromDate IS NULL OR b.CreatedAt >= @FromDate)
      AND (@ToDate IS NULL OR b.CreatedAt <= @ToDate);

    -- Return main statistics
    SELECT * FROM @Stats;

    -- Bookings by status breakdown
    SELECT 
        b.BookingStatus AS [Key],
        COUNT(*) AS [Value]
    FROM Bookings b
    WHERE (@UserId IS NULL OR b.UserId = @UserId)
      AND (@FromDate IS NULL OR b.CreatedAt >= @FromDate)
      AND (@ToDate IS NULL OR b.CreatedAt <= @ToDate)
    GROUP BY b.BookingStatus
    ORDER BY [Value] DESC;

    -- Bookings by month for trend analysis
    SELECT 
        FORMAT(b.CreatedAt, 'yyyy-MM') AS [Key],
        COUNT(*) AS [Value]
    FROM Bookings b
    WHERE (@UserId IS NULL OR b.UserId = @UserId)
      AND (@FromDate IS NULL OR b.CreatedAt >= @FromDate)
      AND (@ToDate IS NULL OR b.CreatedAt <= @ToDate)
    GROUP BY FORMAT(b.CreatedAt, 'yyyy-MM')
    ORDER BY [Key];
END;
GO

-- ───────────────────────────────────────────────────────────
-- sp_GetUserBookingHistory
-- Quick access to user's booking list
-- ───────────────────────────────────────────────────────────

CREATE OR ALTER PROCEDURE sp_GetUserBookingHistory
    @UserId  INT,
    @Status  VARCHAR(20) = NULL,
    @Limit   INT = 20
AS
BEGIN
    SET NOCOUNT ON;

    SELECT TOP (@Limit)
        b.BookingId,
        b.BookingReference,
        b.PNR,
        b.BookingStatus,
        b.CreatedAt,
        bp.TotalAmount,
        bp.Currency,
        p.PaymentStatus,
        -- Flight summary
        STUFF((
            SELECT ', ' + f.FlightNumber
            FROM BookingFlights bf
            INNER JOIN Flights f ON bf.FlightId = f.FlightId
            WHERE bf.BookingId = b.BookingId
            ORDER BY f.DepartureDateTime
            FOR XML PATH('')
        ), 1, 2, '') AS FlightNumbers,
        -- Passenger count
        (SELECT COUNT(*) FROM Passengers WHERE BookingId = b.BookingId) AS PassengerCount,
        -- First flight departure
        (SELECT MIN(f.DepartureDateTime) 
         FROM BookingFlights bf 
         INNER JOIN Flights f ON bf.FlightId = f.FlightId 
         WHERE bf.BookingId = b.BookingId) AS DepartureDate
    FROM Bookings b
    LEFT JOIN BookingPricings bp ON b.BookingId = bp.BookingId
    LEFT JOIN Payments p ON b.BookingId = p.BookingId
    WHERE b.UserId = @UserId
      AND (@Status IS NULL OR b.BookingStatus = @Status)
    ORDER BY b.CreatedAt DESC;
END;
GO

-- ───────────────────────────────────────────────────────────
-- sp_GetBookingDetailedHistory
-- Full booking details with all related entities
-- ───────────────────────────────────────────────────────────

CREATE OR ALTER PROCEDURE sp_GetBookingDetailedHistory
    @BookingId INT
AS
BEGIN
    SET NOCOUNT ON;

    -- Booking header
    SELECT 
        b.*,
        bp.*,
        p.PaymentStatus,
        p.PaymentMethod,
        p.TransactionId,
        p.PaidAt
    FROM Bookings b
    LEFT JOIN BookingPricings bp ON b.BookingId = bp.BookingId
    LEFT JOIN Payments p ON b.BookingId = p.BookingId
    WHERE b.BookingId = @BookingId;

    -- Passengers
    SELECT 
        p.*,
        pt.TicketNumber,
        pt.SeatNumber,
        pt.SeatClass,
        pt.Gate,
        pt.BoardingTime
    FROM Passengers p
    LEFT JOIN PassengerTickets pt ON p.PassengerId = pt.PassengerId
    WHERE p.BookingId = @BookingId
    ORDER BY p.PassengerId;

    -- Flights
    SELECT 
        f.*,
        orig.AirportCode AS OriginCode,
        orig.AirportName AS OriginName,
        orig.City AS OriginCity,
        orig.Country AS OriginCountry,
        dest.AirportCode AS DestinationCode,
        dest.AirportName AS DestinationName,
        dest.City AS DestinationCity,
        dest.Country AS DestinationCountry,
        a.AirlineName,
        a.AirlineCode
    FROM BookingFlights bf
    INNER JOIN Flights f ON bf.FlightId = f.FlightId
    INNER JOIN Airports orig ON f.OriginAirportId = orig.AirportId
    INNER JOIN Airports dest ON f.DestinationAirportId = dest.AirportId
    INNER JOIN Airlines a ON f.AirlineId = a.AirlineId
    WHERE bf.BookingId = @BookingId
    ORDER BY f.DepartureDateTime;

    -- Seat reservations
    SELECT 
        sr.*,
        s.SeatNumber,
        s.SeatClass,
        s.SeatType
    FROM SeatReservations sr
    INNER JOIN Seats s ON sr.SeatId = s.SeatId
    WHERE sr.BookingId = @BookingId;

    -- Audit trail
    SELECT 
        *
    FROM BookingAuditLog
    WHERE BookingId = @BookingId
    ORDER BY ActionTimestamp DESC;
END;
GO

PRINT 'Booking history and statistics stored procedures created successfully';