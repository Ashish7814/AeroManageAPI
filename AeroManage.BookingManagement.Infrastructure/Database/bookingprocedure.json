-- Seat Repository Stored Procedures
-- =============================================

USE AirlineManagementDB;
GO

-- =============================================
-- SP: Get Flight Seats with availability
-- =============================================
CREATE OR ALTER PROCEDURE sp_GetFlightSeats
    @FlightId INT
AS
BEGIN
    SET NOCOUNT ON;

    DECLARE @AircraftId INT = (SELECT AircraftId FROM Flights WHERE FlightId = @FlightId);

    SELECT
        s.SeatId,
        s.AircraftId,
        s.SeatNumber,
        s.SeatClass,
        s.SeatType,
        s.IsExitRow,
        s.ExtraLegroom,
        s.Price,
        CASE
            WHEN sr.SeatId IS NOT NULL THEN 0
            ELSE s.IsAvailable
        END AS IsAvailable
    FROM Seats s
    LEFT JOIN SeatReservations sr
        ON sr.SeatId = s.SeatId
        AND sr.FlightId = @FlightId
        AND sr.ReservationStatus IN ('Reserved', 'Confirmed')
    WHERE s.AircraftId = @AircraftId
    ORDER BY
        CASE s.SeatClass
            WHEN 'FirstClass' THEN 1
            WHEN 'Business'   THEN 2
            WHEN 'Economy'    THEN 3
            ELSE 4
        END,
        s.SeatNumber;
END
GO

-- =============================================
-- SP: Reserve Seat with hold timer
-- =============================================
CREATE OR ALTER PROCEDURE sp_ReserveSeat
    @FlightId           INT,
    @SeatId             INT,
    @BookingPassengerId INT,
    @HoldMinutes        INT = 15
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRANSACTION;
    BEGIN TRY

        -- Check for active reservation
        IF EXISTS (
            SELECT 1 FROM SeatReservations
            WHERE SeatId = @SeatId
              AND FlightId = @FlightId
              AND ReservationStatus IN ('Reserved', 'Confirmed')
        )
        BEGIN
            ROLLBACK TRANSACTION;
            THROW 50001, 'Seat is already reserved or confirmed', 1;
            RETURN;
        END

        -- Clean up any expired holds for this seat
        DELETE FROM SeatReservations
        WHERE SeatId = @SeatId
          AND FlightId = @FlightId
          AND ReservationStatus = 'Hold'
          AND ExpiresAt < GETDATE();

        -- Insert new reservation
        INSERT INTO SeatReservations (
            FlightId, SeatId, BookingPassengerId,
            ReservationStatus, ExpiresAt, CreatedAt
        )
        VALUES (
            @FlightId, @SeatId, @BookingPassengerId,
            'Reserved', DATEADD(MINUTE, @HoldMinutes, GETDATE()), GETDATE()
        );

        DECLARE @ReservationId INT = SCOPE_IDENTITY();
        DECLARE @ExpiresAt DATETIME = DATEADD(MINUTE, @HoldMinutes, GETDATE());

        COMMIT TRANSACTION;

        SELECT
            @ReservationId    AS ReservationId,
            @ExpiresAt        AS ExpiresAt,
            'Reserved'        AS ReservationStatus;

    END TRY
    BEGIN CATCH
        ROLLBACK TRANSACTION;
        THROW;
    END CATCH
END
GO

-- =============================================
-- SP: Confirm Seat Reservations after payment
-- =============================================
CREATE OR ALTER PROCEDURE sp_ConfirmSeatReservations
    @BookingId INT
AS
BEGIN
    SET NOCOUNT ON;

    UPDATE sr
    SET sr.ReservationStatus = 'Confirmed',
        sr.ConfirmedAt       = GETDATE()
    FROM SeatReservations sr
    INNER JOIN BookingPassengers bp
        ON sr.BookingPassengerId = bp.BookingPassengerId
    WHERE bp.BookingId = @BookingId
      AND sr.ReservationStatus = 'Reserved';

    SELECT @@ROWCOUNT AS ConfirmedCount;
END
GO

-- =============================================
-- SP: Release single reservation
-- =============================================
CREATE OR ALTER PROCEDURE sp_ReleaseSeatReservation
    @ReservationId INT
AS
BEGIN
    SET NOCOUNT ON;

    UPDATE SeatReservations
    SET ReservationStatus = 'Released'
    WHERE ReservationId = @ReservationId
      AND ReservationStatus IN ('Reserved', 'Hold');

    SELECT @@ROWCOUNT AS Released;
END
GO

-- =============================================
-- SP: Release expired reservations (scheduler)
-- =============================================
CREATE OR ALTER PROCEDURE sp_ReleaseExpiredReservations
AS
BEGIN
    SET NOCOUNT ON;

    UPDATE SeatReservations
    SET ReservationStatus = 'Expired'
    WHERE ReservationStatus = 'Reserved'
      AND ExpiresAt < GETDATE();

    SELECT @@ROWCOUNT AS ReleasedCount;
END
GO

-- =============================================
-- SP: Check seat availability
-- =============================================
CREATE OR ALTER PROCEDURE sp_IsSeatAvailable
    @FlightId INT,
    @SeatId   INT
AS
BEGIN
    SET NOCOUNT ON;

    SELECT CASE
        WHEN EXISTS (
            SELECT 1 FROM SeatReservations
            WHERE SeatId   = @SeatId
              AND FlightId = @FlightId
              AND ReservationStatus IN ('Reserved', 'Confirmed')
        ) THEN 0
        WHEN EXISTS (
            SELECT 1 FROM Seats
            WHERE SeatId = @SeatId AND IsAvailable = 1
        ) THEN 1
        ELSE 0
    END AS IsAvailable;
END
GO

