-- =============================================
-- SP: Generate Boarding Pass
-- =============================================
CREATE OR ALTER PROCEDURE sp_GenerateBoardingPass
    @BookingPassengerId INT,
    @Gate NVARCHAR(10),
    @BoardingTime DATETIME,
    @BoardingGroup NVARCHAR(10) = NULL,
    @BoardingZone INT = NULL
AS
BEGIN
    SET NOCOUNT ON;
    
    -- Check if boarding pass already exists
    IF EXISTS (SELECT 1 FROM BoardingPasses WHERE BookingPassengerId = @BookingPassengerId)
    BEGIN
        -- Return existing boarding pass
        SELECT 
            BoardingPassId,
            BoardingPassNumber,
            QRCode
        FROM BoardingPasses
        WHERE BookingPassengerId = @BookingPassengerId;
        RETURN;
    END
    
    DECLARE @BoardingPassNumber NVARCHAR(20) = 
        'BP' + CAST(@BookingPassengerId AS NVARCHAR) + CAST(ABS(CHECKSUM(NEWID())) % 1000 AS NVARCHAR);
    
    -- Generate QR code data (PNR|Passenger|Flight|Seat)
    DECLARE @QRCode NVARCHAR(MAX);
    
    SELECT @QRCode = 
        b.PNR + '|' +
        p.FirstName + ' ' + p.LastName + '|' +
        ISNULL(f.FlightNumber, 'TBA') + '|' +
        ISNULL(bp.SeatNumber, 'TBA')
    FROM BookingPassengers bp
    INNER JOIN Passengers p ON bp.PassengerId = p.PassengerId
    INNER JOIN Bookings b ON bp.BookingId = b.BookingId
    LEFT JOIN BookingFlights bf ON bf.BookingId = b.BookingId
    LEFT JOIN Flights f ON bf.FlightId = f.FlightId
    WHERE bp.BookingPassengerId = @BookingPassengerId;
    
    -- Determine boarding group if not provided
    IF @BoardingGroup IS NULL
    BEGIN
        DECLARE @SeatClass NVARCHAR(20);
        SELECT @SeatClass = SeatClass FROM BookingPassengers WHERE BookingPassengerId = @BookingPassengerId;
        
        SET @BoardingGroup = CASE @SeatClass
            WHEN 'FirstClass' THEN 'A'
            WHEN 'Business' THEN 'B'
            WHEN 'Economy' THEN 'C'
            ELSE 'D'
        END;
        
        SET @BoardingZone = CASE @SeatClass
            WHEN 'FirstClass' THEN 1
            WHEN 'Business' THEN 2
            WHEN 'Economy' THEN 3
            ELSE 4
        END;
    END
    
    -- Insert boarding pass
    INSERT INTO BoardingPasses (
        BookingPassengerId, 
        BoardingPassNumber, 
        Gate, 
        BoardingTime,
        BoardingGroup,
        BoardingZone,
        QRCode
    )
    VALUES (
        @BookingPassengerId, 
        @BoardingPassNumber, 
        @Gate, 
        @BoardingTime,
        @BoardingGroup,
        @BoardingZone,
        @QRCode
    );
    
    SELECT 
        SCOPE_IDENTITY() AS BoardingPassId,
        @BoardingPassNumber AS BoardingPassNumber,
        @QRCode AS QRCode,
        @BoardingGroup AS BoardingGroup,
        @BoardingZone AS BoardingZone;
END
GO

-- =============================================
-- SP: Get Boarding Pass
-- =============================================
CREATE OR ALTER PROCEDURE sp_GetBoardingPass
    @BoardingPassId INT = NULL,
    @BoardingPassNumber NVARCHAR(20) = NULL,
    @BookingPassengerId INT = NULL
AS
BEGIN
    SET NOCOUNT ON;
    
    SELECT 
        bp.BoardingPassId,
        bp.BoardingPassNumber,
        bp.Gate,
        bp.BoardingTime,
        bp.BoardingGroup,
        bp.BoardingZone,
        bp.QRCode,
        bp.Barcode,
        bp.IsUsed,
        bp.ScannedAt,
        bp.GeneratedAt,
        -- Passenger info
        p.FirstName,
        p.LastName,
        p.Email,
        -- Booking info
        b.BookingReference,
        b.PNR,
        bkp.SeatNumber,
        bkp.SeatClass,
        -- Flight info
        f.FlightNumber,
        f.DepartureDateTime,
        oa.AirportCode AS OriginCode,
        da.AirportCode AS DestinationCode
    FROM BoardingPasses bp
    INNER JOIN BookingPassengers bkp ON bp.BookingPassengerId = bkp.BookingPassengerId
    INNER JOIN Passengers p ON bkp.PassengerId = p.PassengerId
    INNER JOIN Bookings b ON bkp.BookingId = b.BookingId
    LEFT JOIN BookingFlights bf ON bf.BookingId = b.BookingId
    LEFT JOIN Flights f ON bf.FlightId = f.FlightId
    LEFT JOIN Routes r ON f.RouteId = r.RouteId
    LEFT JOIN Airports oa ON r.OriginAirportId = oa.AirportId
    LEFT JOIN Airports da ON r.DestinationAirportId = da.AirportId
    WHERE 
        (@BoardingPassId IS NOT NULL AND bp.BoardingPassId = @BoardingPassId)
        OR (@BoardingPassNumber IS NOT NULL AND bp.BoardingPassNumber = @BoardingPassNumber)
        OR (@BookingPassengerId IS NOT NULL AND bp.BookingPassengerId = @BookingPassengerId);
END
GO

-- =============================================
-- SP: Scan Boarding Pass
-- =============================================
CREATE OR ALTER PROCEDURE sp_ScanBoardingPass
    @BoardingPassNumber NVARCHAR(20),
    @ScannedBy NVARCHAR(100)
AS
BEGIN
    SET NOCOUNT ON;
    
    -- Check if boarding pass exists
    IF NOT EXISTS (SELECT 1 FROM BoardingPasses WHERE BoardingPassNumber = @BoardingPassNumber)
    BEGIN
        SELECT 0 AS Success, 'Invalid boarding pass' AS Message;
        RETURN;
    END
    
    -- Check if already scanned
    IF EXISTS (SELECT 1 FROM BoardingPasses WHERE BoardingPassNumber = @BoardingPassNumber AND IsUsed = 1)
    BEGIN
        SELECT 0 AS Success, 'Boarding pass already scanned' AS Message;
        RETURN;
    END
    
    -- Mark as scanned
    UPDATE BoardingPasses
    SET IsUsed = 1,
        ScannedAt = GETDATE(),
        ScannedBy = @ScannedBy
    WHERE BoardingPassNumber = @BoardingPassNumber;
    
    -- Return passenger info
    SELECT 
        1 AS Success,
        'Boarding pass scanned successfully' AS Message,
        p.FirstName,
        p.LastName,
        bp.SeatNumber,
        bp.SeatClass,
        f.FlightNumber,
        bpass.BoardingGroup,
        bpass.Gate
    FROM BoardingPasses bpass
    INNER JOIN BookingPassengers bp ON bpass.BookingPassengerId = bp.BookingPassengerId
    INNER JOIN Passengers p ON bp.PassengerId = p.PassengerId
    INNER JOIN Bookings b ON bp.BookingId = b.BookingId
    LEFT JOIN BookingFlights bf ON bf.BookingId = b.BookingId
    LEFT JOIN Flights f ON bf.FlightId = f.FlightId
    WHERE bpass.BoardingPassNumber = @BoardingPassNumber;
END
GO

