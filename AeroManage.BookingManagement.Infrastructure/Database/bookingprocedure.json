-- =============================================
-- SP: Get Calendar Fares (Enhanced)
-- =============================================
CREATE OR ALTER PROCEDURE sp_GetCalendarFares
    @OriginAirportId INT,
    @DestinationAirportId INT,
    @StartDate DATE,
    @EndDate DATE,
    @SeatClass NVARCHAR(20) = 'Economy'
AS
BEGIN
    SET NOCOUNT ON;
    
    WITH DateRange AS (
        SELECT @StartDate AS FlightDate
        UNION ALL
        SELECT DATEADD(DAY, 1, FlightDate)
        FROM DateRange
        WHERE FlightDate < @EndDate
    ),
    FlightFares AS (
        SELECT 
            CAST(f.DepartureDateTime AS DATE) AS FlightDate,
            MIN(CASE @SeatClass
                WHEN 'Economy' THEN f.EconomyPrice
                WHEN 'Business' THEN f.BusinessPrice
                WHEN 'FirstClass' THEN f.FirstClassPrice
                ELSE f.EconomyPrice
            END) AS MinPrice,
            COUNT(*) AS AvailableFlights
        FROM Flights f
        INNER JOIN Routes r ON f.RouteId = r.RouteId
        WHERE r.OriginAirportId = @OriginAirportId
            AND r.DestinationAirportId = @DestinationAirportId
            AND f.FlightStatus IN ('Scheduled', 'Boarding')
            AND CAST(f.DepartureDateTime AS DATE) BETWEEN @StartDate AND @EndDate
        GROUP BY CAST(f.DepartureDateTime AS DATE)
    )
    SELECT 
        dr.FlightDate AS Date,
        ISNULL(ff.MinPrice, 0) AS MinPrice,
        ISNULL(ff.AvailableFlights, 0) AS AvailableFlights,
        CASE WHEN ff.MinPrice IS NOT NULL THEN 1 ELSE 0 END AS IsAvailable
    FROM DateRange dr
    LEFT JOIN FlightFares ff ON dr.FlightDate = ff.FlightDate
    ORDER BY dr.FlightDate
    OPTION (MAXRECURSION 365);
END
GO

-- =============================================
-- SP: Get Flight Details (Enhanced)
-- =============================================
CREATE OR ALTER PROCEDURE sp_GetFlightDetails
    @FlightId INT
AS
BEGIN
    SET NOCOUNT ON;
    
    -- Flight details
    SELECT 
        f.FlightId,
        f.FlightNumber,
        f.FlightStatus,
        f.DepartureDateTime,
        f.ArrivalDateTime,
        f.DepartureGate,
        f.ArrivalGate,
        f.EconomyPrice,
        f.BusinessPrice,
        f.FirstClassPrice,
        -- Route
        r.RouteId,
        r.RouteCode,
        r.Distance,
        r.EstimatedDuration,
        -- Origin Airport
        oa.AirportId AS OriginAirportId,
        oa.AirportCode AS OriginCode,
        oa.AirportName AS OriginName,
        oa.City AS OriginCity,
        oa.Country AS OriginCountry,
        -- Destination Airport
        da.AirportId AS DestinationAirportId,
        da.AirportCode AS DestinationCode,
        da.AirportName AS DestinationName,
        da.City AS DestinationCity,
        da.Country AS DestinationCountry,
        -- Aircraft
        ac.AircraftId,
        ac.Model AS AircraftModel,
        ac.Manufacturer,
        ac.TotalSeats
    FROM Flights f
    INNER JOIN Routes r ON f.RouteId = r.RouteId
    INNER JOIN Airports oa ON r.OriginAirportId = oa.AirportId
    INNER JOIN Airports da ON r.DestinationAirportId = da.AirportId
    LEFT JOIN Aircraft ac ON f.AircraftId = ac.AircraftId
    WHERE f.FlightId = @FlightId;
    
    -- Layovers (if any)
    SELECT 
        rl.LayoverId,
        rl.LayoverSequence,
        rl.MinimumLayoverMinutes,
        rl.MaximumLayoverMinutes,
        a.AirportId,
        a.AirportCode,
        a.AirportName,
        a.City,
        a.Country
    FROM RouteLayovers rl
    INNER JOIN Airports a ON rl.AirportId = a.AirportId
    WHERE rl.RouteId = (SELECT RouteId FROM Flights WHERE FlightId = @FlightId)
    ORDER BY rl.LayoverSequence;
END
GO

-- =============================================
-- SP: Get Seat Availability
-- =============================================
CREATE OR ALTER PROCEDURE sp_GetSeatAvailability
    @FlightId INT,
    @SeatClass NVARCHAR(20) = NULL
AS
BEGIN
    SET NOCOUNT ON;
    
    DECLARE @AircraftId INT = (SELECT AircraftId FROM Flights WHERE FlightId = @FlightId);
    
    SELECT 
        SeatClass,
        COUNT(*) AS TotalSeats,
        SUM(CASE WHEN s.IsAvailable = 1 
            AND NOT EXISTS (
                SELECT 1 FROM SeatReservations sr 
                WHERE sr.SeatId = s.SeatId 
                AND sr.FlightId = @FlightId 
                AND sr.ReservationStatus IN ('Reserved', 'Confirmed')
            ) THEN 1 ELSE 0 END) AS AvailableSeats
    FROM Seats s
    WHERE s.AircraftId = @AircraftId
        AND (@SeatClass IS NULL OR s.SeatClass = @SeatClass)
    GROUP BY s.SeatClass;
END
GO

