-- =============================================
-- AIRPORT STORED PROCEDURES
-- =============================================

-- Create Airport
CREATE OR ALTER PROCEDURE sp_CreateAirport
    @AirportCode NVARCHAR(10),
    @ICAOCode NVARCHAR(10) = NULL,
    @AirportName NVARCHAR(200),
    @City NVARCHAR(100),
    @State NVARCHAR(100) = NULL,
    @Country NVARCHAR(100),
    @Latitude DECIMAL(10, 7) = NULL,
    @Longitude DECIMAL(10, 7) = NULL,
    @Timezone NVARCHAR(50) = NULL
AS
BEGIN
    SET NOCOUNT ON;
    
    IF EXISTS (SELECT 1 FROM Airports WHERE AirportCode = @AirportCode)
    BEGIN
        RAISERROR('Airport code already exists', 16, 1);
        RETURN;
    END
    
    INSERT INTO Airports (AirportCode, ICAOCode, AirportName, City, State, Country, Latitude, Longitude, Timezone)
    VALUES (@AirportCode, @ICAOCode, @AirportName, @City, @State, @Country, @Latitude, @Longitude, @Timezone);
    
    SELECT * FROM Airports WHERE AirportId = SCOPE_IDENTITY();
END
GO

-- Get All Airports
CREATE OR ALTER PROCEDURE sp_GetAllAirports
    @PageNumber INT = 1,
    @PageSize INT = 50,
    @SearchTerm NVARCHAR(100) = NULL,
    @Country NVARCHAR(100) = NULL
AS
BEGIN
    SET NOCOUNT ON;
    
    DECLARE @Offset INT = (@PageNumber - 1) * @PageSize;
    
    SELECT *,
           COUNT(*) OVER() AS TotalRecords
    FROM Airports
    WHERE IsActive = 1
      AND (@SearchTerm IS NULL OR 
           AirportCode LIKE '%' + @SearchTerm + '%' OR 
           AirportName LIKE '%' + @SearchTerm + '%' OR 
           City LIKE '%' + @SearchTerm + '%')
      AND (@Country IS NULL OR Country = @Country)
    ORDER BY AirportName
    OFFSET @Offset ROWS
    FETCH NEXT @PageSize ROWS ONLY;
END
GO

-- Get Airport By Id
CREATE OR ALTER PROCEDURE sp_GetAirportById
    @AirportId INT
AS
BEGIN
    SET NOCOUNT ON;
    SELECT * FROM Airports WHERE AirportId = @AirportId AND IsActive = 1;
END
GO

-- =============================================
-- AIRCRAFT STORED PROCEDURES
