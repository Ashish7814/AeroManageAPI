GO

-- Update Flight Status
CREATE OR ALTER PROCEDURE sp_UpdateFlightStatus
    @FlightId INT,
    @NewStatus NVARCHAR(50),
    @Reason NVARCHAR(500) = NULL,
    @ChangedBy INT
AS
BEGIN
    SET NOCOUNT ON;
    
    BEGIN TRY
        BEGIN TRANSACTION;
        
        DECLARE @OldStatus NVARCHAR(50);
        SELECT @OldStatus = FlightStatus FROM Flights WHERE FlightId = @FlightId;
        
        -- Update flight status
        UPDATE Flights
        SET FlightStatus = @NewStatus,
            UpdatedAt = GETDATE()
        WHERE FlightId = @FlightId;
        
        -- Log status change
        INSERT INTO FlightStatusHistory (FlightId, OldStatus, NewStatus, Reason, ChangedBy)
        VALUES (@FlightId, @OldStatus, @NewStatus, @Reason, @ChangedBy);
        
        -- Update aircraft status based on flight status
        IF @NewStatus = 'Departed' OR @NewStatus = 'InFlight'
        BEGIN
            UPDATE Aircraft
            SET CurrentStatus = 'InFlight'
            WHERE AircraftId = (SELECT AircraftId FROM Flights WHERE FlightId = @FlightId);
        END
        ELSE IF @NewStatus = 'Landed'
        BEGIN
            UPDATE Aircraft
            SET CurrentStatus = 'Available'
            WHERE AircraftId = (SELECT AircraftId FROM Flights WHERE FlightId = @FlightId);
        END
        
        SELECT * FROM Flights WHERE FlightId = @FlightId;
        
        COMMIT TRANSACTION;
    END TRY
    BEGIN CATCH
        ROLLBACK TRANSACTION;
        THROW;
    END CATCH
END
GO

-- Assign Crew to Flight
CREATE OR ALTER PROCEDURE sp_AssignFlightCrew
    @FlightId INT,
    @UserId INT,
    @CrewRole NVARCHAR(50)
AS
BEGIN
    SET NOCOUNT ON;
    
    -- Check if already assigned
    IF EXISTS (SELECT 1 FROM FlightCrew WHERE FlightId = @FlightId AND UserId = @UserId)
    BEGIN
        RAISERROR('Crew member already assigned to this flight', 16, 1);
        RETURN;
    END
    
    INSERT INTO FlightCrew (FlightId, UserId, CrewRole)
    VALUES (@FlightId, @UserId, @CrewRole);
    
    SELECT fc.*, u.FirstName, u.LastName, u.Email
    FROM FlightCrew fc
    INNER JOIN Users u ON fc.UserId = u.UserId
    WHERE fc.FlightCrewId = SCOPE_IDENTITY();
END
GO

-- Get Flight Crew
CREATE OR ALTER PROCEDURE sp_GetFlightCrew
    @FlightId INT
AS
BEGIN
    SET NOCOUNT ON;
    
    SELECT fc.*, u.FirstName, u.LastName, u.Email, u.PhoneNumber
    FROM FlightCrew fc
    INNER JOIN Users u ON fc.UserId = u.UserId
    WHERE fc.FlightId = @FlightId
    ORDER BY fc.CrewRole;
END
GO

-- Get Flight Status History
CREATE OR ALTER PROCEDURE sp_GetFlightStatusHistory
    @FlightId INT
AS
BEGIN
    SET NOCOUNT ON;
    
    SELECT fsh.*, u.FirstName + ' ' + u.LastName AS ChangedByName
    FROM FlightStatusHistory fsh
    LEFT JOIN Users u ON fsh.ChangedBy = u.UserId
    WHERE fsh.FlightId = @FlightId
    ORDER BY fsh.ChangedAt DESC;
END
GO

