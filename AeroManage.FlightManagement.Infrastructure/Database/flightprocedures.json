-- Create Aircraft
CREATE OR ALTER PROCEDURE sp_CreateAircraft
    @RegistrationNumber NVARCHAR(50),
    @AircraftType NVARCHAR(100),
    @Manufacturer NVARCHAR(100) = NULL,
    @Model NVARCHAR(100) = NULL,
    @YearManufactured INT = NULL,
    @TotalSeats INT,
    @EconomySeats INT,
    @BusinessSeats INT,
    @FirstClassSeats INT
AS
BEGIN
    SET NOCOUNT ON;
    
    IF EXISTS (SELECT 1 FROM Aircraft WHERE RegistrationNumber = @RegistrationNumber)
    BEGIN
        RAISERROR('Aircraft registration number already exists', 16, 1);
        RETURN;
    END
    
    INSERT INTO Aircraft (RegistrationNumber, AircraftType, Manufacturer, Model, YearManufactured, 
                         TotalSeats, EconomySeats, BusinessSeats, FirstClassSeats)
    VALUES (@RegistrationNumber, @AircraftType, @Manufacturer, @Model, @YearManufactured,
            @TotalSeats, @EconomySeats, @BusinessSeats, @FirstClassSeats);
    
    SELECT * FROM Aircraft WHERE AircraftId = SCOPE_IDENTITY();
END
GO

-- Get All Aircraft
CREATE OR ALTER PROCEDURE sp_GetAllAircraft
    @PageNumber INT = 1,
    @PageSize INT = 50,
    @Status NVARCHAR(50) = NULL
AS
BEGIN
    SET NOCOUNT ON;
    
    DECLARE @Offset INT = (@PageNumber - 1) * @PageSize;
    
    SELECT *,
           COUNT(*) OVER() AS TotalRecords
    FROM Aircraft
    WHERE IsActive = 1
      AND (@Status IS NULL OR CurrentStatus = @Status)
    ORDER BY RegistrationNumber
    OFFSET @Offset ROWS
    FETCH NEXT @PageSize ROWS ONLY;
END
GO

-- Get Aircraft By Id
CREATE OR ALTER PROCEDURE sp_GetAircraftById
    @AircraftId INT
AS
BEGIN
    SET NOCOUNT ON;
    SELECT * FROM Aircraft WHERE AircraftId = @AircraftId AND IsActive = 1;
END
GO

-- Update Aircraft Status
CREATE OR ALTER PROCEDURE sp_UpdateAircraftStatus
    @AircraftId INT,
    @Status NVARCHAR(50)
AS
BEGIN
    SET NOCOUNT ON;
    
    UPDATE Aircraft
    SET CurrentStatus = @Status,
        UpdatedAt = GETDATE()
    WHERE AircraftId = @AircraftId;
    
    SELECT * FROM Aircraft WHERE AircraftId = @AircraftId;
END
GO

-- =============================================
-- ROUTE STORED PROCEDURES
-- =============================================

-- Create Route
CREATE OR ALTER PROCEDURE sp_CreateRoute
    @RouteCode NVARCHAR(20),
    @OriginAirportId INT,
    @DestinationAirportId INT,
    @Distance INT = NULL,
    @EstimatedDuration INT = NULL
AS
BEGIN
    SET NOCOUNT ON;
    
    IF EXISTS (SELECT 1 FROM Routes WHERE RouteCode = @RouteCode)
    BEGIN
        RAISERROR('Route code already exists', 16, 1);
        RETURN;
    END
    
    IF @OriginAirportId = @DestinationAirportId
    BEGIN
        RAISERROR('Origin and destination airports must be different', 16, 1);
        RETURN;
    END
    
    INSERT INTO Routes (RouteCode, OriginAirportId, DestinationAirportId, Distance, EstimatedDuration)
    VALUES (@RouteCode, @OriginAirportId, @DestinationAirportId, @Distance, @EstimatedDuration);
    
    SELECT r.*, 
           oa.AirportCode AS OriginCode, oa.AirportName AS OriginName, oa.City AS OriginCity,
           da.AirportCode AS DestinationCode, da.AirportName AS DestinationName, da.City AS DestinationCity
    FROM Routes r
    INNER JOIN Airports oa ON r.OriginAirportId = oa.AirportId
    INNER JOIN Airports da ON r.DestinationAirportId = da.AirportId
    WHERE r.RouteId = SCOPE_IDENTITY();
END
GO

-- Get All Routes
CREATE OR ALTER PROCEDURE sp_GetAllRoutes
    @PageNumber INT = 1,
    @PageSize INT = 50
AS
BEGIN
    SET NOCOUNT ON;
    
    DECLARE @Offset INT = (@PageNumber - 1) * @PageSize;
    
    SELECT r.*, 
           oa.AirportCode AS OriginCode, oa.AirportName AS OriginName, oa.City AS OriginCity, oa.Country AS OriginCountry,
           da.AirportCode AS DestinationCode, da.AirportName AS DestinationName, da.City AS DestinationCity, da.Country AS DestinationCountry,
           COUNT(*) OVER() AS TotalRecords
    FROM Routes r
    INNER JOIN Airports oa ON r.OriginAirportId = oa.AirportId
    INNER JOIN Airports da ON r.DestinationAirportId = da.AirportId
    WHERE r.IsActive = 1
    ORDER BY r.RouteCode
    OFFSET @Offset ROWS
    FETCH NEXT @PageSize ROWS ONLY;
END
GO

-- Get Route By Id
CREATE OR ALTER PROCEDURE sp_GetRouteById
    @RouteId INT
AS
BEGIN
    SET NOCOUNT ON;
    
    SELECT r.*, 
           oa.AirportCode AS OriginCode, oa.AirportName AS OriginName, oa.City AS OriginCity, oa.Country AS OriginCountry,
           da.AirportCode AS DestinationCode, da.AirportName AS DestinationName, da.City AS DestinationCity, da.Country AS DestinationCountry
    FROM Routes r
    INNER JOIN Airports oa ON r.OriginAirportId = oa.AirportId
    INNER JOIN Airports da ON r.DestinationAirportId = da.AirportId
    WHERE r.RouteId = @RouteId AND r.IsActive = 1;
END
GO

-- =============================================
-- FLIGHT STORED PROCEDURES
-- =============================================

-- Create Flight
CREATE OR ALTER PROCEDURE sp_CreateFlight
    @FlightNumber NVARCHAR(20),
    @RouteId INT,
    @AircraftId INT,
    @DepartureDateTime DATETIME,
    @ArrivalDateTime DATETIME,
    @EconomyPrice DECIMAL(10, 2),
    @BusinessPrice DECIMAL(10, 2),
    @FirstClassPrice DECIMAL(10, 2),
    @DepartureGate NVARCHAR(10) = NULL,
    @ArrivalGate NVARCHAR(10) = NULL,
    @CreatedBy INT
AS
BEGIN
    SET NOCOUNT ON;
    
    BEGIN TRY
        BEGIN TRANSACTION;
        
        -- Get aircraft seat configuration
        DECLARE @EconomySeats INT, @BusinessSeats INT, @FirstClassSeats INT;
        
        SELECT @EconomySeats = EconomySeats,
               @BusinessSeats = BusinessSeats,
               @FirstClassSeats = FirstClassSeats
        FROM Aircraft
        WHERE AircraftId = @AircraftId AND IsActive = 1;
        
        IF @EconomySeats IS NULL
        BEGIN
            RAISERROR('Aircraft not found or inactive', 16, 1);
            RETURN;
        END
        
        -- Create flight
        INSERT INTO Flights (FlightNumber, RouteId, AircraftId, DepartureDateTime, ArrivalDateTime,
                            EconomyPrice, BusinessPrice, FirstClassPrice, DepartureGate, ArrivalGate,
                            AvailableEconomySeats, AvailableBusinessSeats, AvailableFirstClassSeats, CreatedBy)
        VALUES (@FlightNumber, @RouteId, @AircraftId, @DepartureDateTime, @ArrivalDateTime,
                @EconomyPrice, @BusinessPrice, @FirstClassPrice, @DepartureGate, @ArrivalGate,
                @EconomySeats, @BusinessSeats, @FirstClassSeats, @CreatedBy);
        
        DECLARE @FlightId INT = SCOPE_IDENTITY();
        
        -- Return flight details
        SELECT f.*,
               r.RouteCode,
               oa.AirportCode AS OriginCode, oa.AirportName AS OriginName, oa.City AS OriginCity,
               da.AirportCode AS DestinationCode, da.AirportName AS DestinationName, da.City AS DestinationCity,
               a.RegistrationNumber, a.AircraftType
        FROM Flights f
        INNER JOIN Routes r ON f.RouteId = r.RouteId
        INNER JOIN Airports oa ON r.OriginAirportId = oa.AirportId
        INNER JOIN Airports da ON r.DestinationAirportId = da.AirportId
        INNER JOIN Aircraft a ON f.AircraftId = a.AircraftId
        WHERE f.FlightId = @FlightId;
        
        COMMIT TRANSACTION;
    END TRY
    BEGIN CATCH
        ROLLBACK TRANSACTION;
        THROW;
    END CATCH
END
GO

-- Search Flights
CREATE OR ALTER PROCEDURE sp_SearchFlights
    @OriginAirportId INT = NULL,
    @DestinationAirportId INT = NULL,
    @DepartureDate DATE = NULL,
    @FlightNumber NVARCHAR(20) = NULL,
    @PageNumber INT = 1,
    @PageSize INT = 20
AS
BEGIN
    SET NOCOUNT ON;
    
    DECLARE @Offset INT = (@PageNumber - 1) * @PageSize;
    
    SELECT f.*,
           r.RouteCode, r.Distance, r.EstimatedDuration,
           oa.AirportCode AS OriginCode, oa.AirportName AS OriginName, oa.City AS OriginCity, oa.Country AS OriginCountry,
           da.AirportCode AS DestinationCode, da.AirportName AS DestinationName, da.City AS DestinationCity, da.Country AS DestinationCountry,
           a.RegistrationNumber, a.AircraftType, a.TotalSeats,
           COUNT(*) OVER() AS TotalRecords
    FROM Flights f
    INNER JOIN Routes r ON f.RouteId = r.RouteId
    INNER JOIN Airports oa ON r.OriginAirportId = oa.AirportId
    INNER JOIN Airports da ON r.DestinationAirportId = da.AirportId
    INNER JOIN Aircraft a ON f.AircraftId = a.AircraftId
    WHERE (@OriginAirportId IS NULL OR r.OriginAirportId = @OriginAirportId)
      AND (@DestinationAirportId IS NULL OR r.DestinationAirportId = @DestinationAirportId)
      AND (@DepartureDate IS NULL OR CAST(f.DepartureDateTime AS DATE) = @DepartureDate)
      AND (@FlightNumber IS NULL OR f.FlightNumber LIKE '%' + @FlightNumber + '%')
      AND f.DepartureDateTime >= GETDATE()
    ORDER BY f.DepartureDateTime
    OFFSET @Offset ROWS
    FETCH NEXT @PageSize ROWS ONLY;
END
GO

