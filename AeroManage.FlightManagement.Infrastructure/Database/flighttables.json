-- =============================================
-- Airline Management System - Flight Management Module
-- Database Schema
-- =============================================

USE AirlineManagementDB;
GO

-- =============================================
-- Table: Airports
-- =============================================
IF NOT EXISTS (SELECT * FROM sys.tables WHERE name = 'Airports')
BEGIN
    CREATE TABLE Airports (
        AirportId INT IDENTITY(1,1) PRIMARY KEY,
        AirportCode NVARCHAR(10) NOT NULL UNIQUE, -- IATA code (e.g., JFK, LAX)
        ICAOCode NVARCHAR(10), -- ICAO code
        AirportName NVARCHAR(200) NOT NULL,
        City NVARCHAR(100) NOT NULL,
        State NVARCHAR(100),
        Country NVARCHAR(100) NOT NULL,
        Latitude DECIMAL(10, 7),
        Longitude DECIMAL(10, 7),
        Timezone NVARCHAR(50),
        IsActive BIT DEFAULT 1,
        CreatedAt DATETIME DEFAULT GETDATE(),
        UpdatedAt DATETIME DEFAULT GETDATE()
    );
END
GO

-- =============================================
-- Table: Aircraft
-- =============================================
IF NOT EXISTS (SELECT * FROM sys.tables WHERE name = 'Aircraft')
BEGIN
    CREATE TABLE Aircraft (
        AircraftId INT IDENTITY(1,1) PRIMARY KEY,
        RegistrationNumber NVARCHAR(50) NOT NULL UNIQUE,
        AircraftType NVARCHAR(100) NOT NULL, -- e.g., Boeing 737, Airbus A320
        Manufacturer NVARCHAR(100),
        Model NVARCHAR(100),
        YearManufactured INT,
        TotalSeats INT NOT NULL,
        EconomySeats INT NOT NULL,
        BusinessSeats INT NOT NULL,
        FirstClassSeats INT NOT NULL,
        CurrentStatus NVARCHAR(50) DEFAULT 'Available', -- Available, InFlight, Maintenance, OutOfService
        LastMaintenanceDate DATETIME,
        NextMaintenanceDate DATETIME,
        IsActive BIT DEFAULT 1,
        CreatedAt DATETIME DEFAULT GETDATE(),
        UpdatedAt DATETIME DEFAULT GETDATE()
    );
END
GO

-- =============================================
-- Table: Routes
-- =============================================
IF NOT EXISTS (SELECT * FROM sys.tables WHERE name = 'Routes')
BEGIN
    CREATE TABLE Routes (
        RouteId INT IDENTITY(1,1) PRIMARY KEY,
        RouteCode NVARCHAR(20) NOT NULL UNIQUE,
        OriginAirportId INT NOT NULL,
        DestinationAirportId INT NOT NULL,
        Distance INT, -- in kilometers
        EstimatedDuration INT, -- in minutes
        IsActive BIT DEFAULT 1,
        CreatedAt DATETIME DEFAULT GETDATE(),
        UpdatedAt DATETIME DEFAULT GETDATE(),
        CONSTRAINT FK_Routes_OriginAirport FOREIGN KEY (OriginAirportId) REFERENCES Airports(AirportId),
        CONSTRAINT FK_Routes_DestinationAirport FOREIGN KEY (DestinationAirportId) REFERENCES Airports(AirportId),
        CONSTRAINT CHK_Routes_DifferentAirports CHECK (OriginAirportId != DestinationAirportId)
    );
END
GO

-- =============================================
-- Table: Flights
-- =============================================
IF NOT EXISTS (SELECT * FROM sys.tables WHERE name = 'Flights')
BEGIN
    CREATE TABLE Flights (
        FlightId INT IDENTITY(1,1) PRIMARY KEY,
        FlightNumber NVARCHAR(20) NOT NULL,
        RouteId INT NOT NULL,
        AircraftId INT NOT NULL,
        DepartureDateTime DATETIME NOT NULL,
        ArrivalDateTime DATETIME NOT NULL,
        ActualDepartureDateTime DATETIME,
        ActualArrivalDateTime DATETIME,
        FlightStatus NVARCHAR(50) DEFAULT 'Scheduled', -- Scheduled, Boarding, Departed, InFlight, Landed, Delayed, Cancelled
        DepartureGate NVARCHAR(10),
        ArrivalGate NVARCHAR(10),
        EconomyPrice DECIMAL(10, 2) NOT NULL,
        BusinessPrice DECIMAL(10, 2) NOT NULL,
        FirstClassPrice DECIMAL(10, 2) NOT NULL,
        AvailableEconomySeats INT NOT NULL,
        AvailableBusinessSeats INT NOT NULL,
        AvailableFirstClassSeats INT NOT NULL,
        CreatedBy INT,
        CreatedAt DATETIME DEFAULT GETDATE(),
        UpdatedAt DATETIME DEFAULT GETDATE(),
        CONSTRAINT FK_Flights_Routes FOREIGN KEY (RouteId) REFERENCES Routes(RouteId),
        CONSTRAINT FK_Flights_Aircraft FOREIGN KEY (AircraftId) REFERENCES Aircraft(AircraftId),
        CONSTRAINT FK_Flights_CreatedBy FOREIGN KEY (CreatedBy) REFERENCES Users(UserId)
    );
END
GO

-- =============================================
-- Table: FlightCrew
-- =============================================
IF NOT EXISTS (SELECT * FROM sys.tables WHERE name = 'FlightCrew')
BEGIN
    CREATE TABLE FlightCrew (
        FlightCrewId INT IDENTITY(1,1) PRIMARY KEY,
        FlightId INT NOT NULL,
        UserId INT NOT NULL, -- Staff member from Users table
        CrewRole NVARCHAR(50) NOT NULL, -- Pilot, CoPilot, FlightAttendant, etc.
        AssignedAt DATETIME DEFAULT GETDATE(),
        CONSTRAINT FK_FlightCrew_Flights FOREIGN KEY (FlightId) REFERENCES Flights(FlightId) ON DELETE CASCADE,
        CONSTRAINT FK_FlightCrew_Users FOREIGN KEY (UserId) REFERENCES Users(UserId)
    );
END
GO

-- =============================================
-- Table: FlightStatusHistory
-- =============================================
IF NOT EXISTS (SELECT * FROM sys.tables WHERE name = 'FlightStatusHistory')
BEGIN
    CREATE TABLE FlightStatusHistory (
        StatusHistoryId INT IDENTITY(1,1) PRIMARY KEY,
        FlightId INT NOT NULL,
        OldStatus NVARCHAR(50),
        NewStatus NVARCHAR(50) NOT NULL,
        Reason NVARCHAR(500),
        ChangedBy INT,
        ChangedAt DATETIME DEFAULT GETDATE(),
        CONSTRAINT FK_FlightStatusHistory_Flights FOREIGN KEY (FlightId) REFERENCES Flights(FlightId) ON DELETE CASCADE,
        CONSTRAINT FK_FlightStatusHistory_ChangedBy FOREIGN KEY (ChangedBy) REFERENCES Users(UserId)
    );
END
GO

-- =============================================
-- Create Indexes
-- =============================================
CREATE NONCLUSTERED INDEX IX_Flights_FlightNumber ON Flights(FlightNumber);
CREATE NONCLUSTERED INDEX IX_Flights_DepartureDateTime ON Flights(DepartureDateTime);
CREATE NONCLUSTERED INDEX IX_Flights_FlightStatus ON Flights(FlightStatus);
CREATE NONCLUSTERED INDEX IX_Flights_RouteId ON Flights(RouteId);
CREATE NONCLUSTERED INDEX IX_Flights_AircraftId ON Flights(AircraftId);
CREATE NONCLUSTERED INDEX IX_Routes_OriginDestination ON Routes(OriginAirportId, DestinationAirportId);
CREATE NONCLUSTERED INDEX IX_Aircraft_RegistrationNumber ON Aircraft(RegistrationNumber);
CREATE NONCLUSTERED INDEX IX_Aircraft_CurrentStatus ON Aircraft(CurrentStatus);
CREATE NONCLUSTERED INDEX IX_Airports_AirportCode ON Airports(AirportCode);
CREATE NONCLUSTERED INDEX IX_FlightCrew_FlightId ON FlightCrew(FlightId);
CREATE NONCLUSTERED INDEX IX_FlightStatusHistory_FlightId ON FlightStatusHistory(FlightId);
GO

