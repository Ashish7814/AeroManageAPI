-- =============================================
-- Enhanced Flight Management Module - Additional Tables
-- =============================================

USE AirlineManagementDB;
GO

-- =============================================
-- Table: RouteLayovers (For multi-stop routes)
-- =============================================
IF NOT EXISTS (SELECT * FROM sys.tables WHERE name = 'RouteLayovers')
BEGIN
    CREATE TABLE RouteLayovers (
        LayoverId INT IDENTITY(1,1) PRIMARY KEY,
        RouteId INT NOT NULL,
        AirportId INT NOT NULL,
        LayoverSequence INT NOT NULL, -- Order of layover (1, 2, 3...)
        MinimumLayoverMinutes INT DEFAULT 60,
        MaximumLayoverMinutes INT DEFAULT 240,
        IsActive BIT DEFAULT 1,
        CONSTRAINT FK_RouteLayovers_Routes FOREIGN KEY (RouteId) REFERENCES Routes(RouteId) ON DELETE CASCADE,
        CONSTRAINT FK_RouteLayovers_Airports FOREIGN KEY (AirportId) REFERENCES Airports(AirportId)
    );
END
GO

-- =============================================
-- Table: FlightScheduleTemplates (Recurring schedules)
-- =============================================
IF NOT EXISTS (SELECT * FROM sys.tables WHERE name = 'FlightScheduleTemplates')
BEGIN
    CREATE TABLE FlightScheduleTemplates (
        TemplateId INT IDENTITY(1,1) PRIMARY KEY,
        TemplateName NVARCHAR(100) NOT NULL,
        FlightNumberPrefix NVARCHAR(10) NOT NULL, -- e.g., "AA"
        RouteId INT NOT NULL,
        AircraftId INT,
        RecurrenceType NVARCHAR(20) NOT NULL, -- Daily, Weekly, Monthly
        DaysOfWeek NVARCHAR(50), -- e.g., "Mon,Wed,Fri" for weekly
        DayOfMonth INT, -- For monthly (1-31)
        StartDate DATE NOT NULL,
        EndDate DATE,
        DepartureTime TIME NOT NULL,
        ArrivalTime TIME NOT NULL,
        EconomyPrice DECIMAL(10, 2),
        BusinessPrice DECIMAL(10, 2),
        FirstClassPrice DECIMAL(10, 2),
        IsActive BIT DEFAULT 1,
        CreatedAt DATETIME DEFAULT GETDATE(),
        CreatedBy INT,
        CONSTRAINT FK_FlightScheduleTemplates_Routes FOREIGN KEY (RouteId) REFERENCES Routes(RouteId),
        CONSTRAINT FK_FlightScheduleTemplates_Aircraft FOREIGN KEY (AircraftId) REFERENCES Aircraft(AircraftId),
        CONSTRAINT FK_FlightScheduleTemplates_CreatedBy FOREIGN KEY (CreatedBy) REFERENCES Users(UserId)
    );
END
GO

-- =============================================
-- Table: FlightNotifications
-- =============================================
IF NOT EXISTS (SELECT * FROM sys.tables WHERE name = 'FlightNotifications')
BEGIN
    CREATE TABLE FlightNotifications (
        NotificationId INT IDENTITY(1,1) PRIMARY KEY,
        FlightId INT NOT NULL,
        NotificationType NVARCHAR(50) NOT NULL, -- Delay, GateChange, Cancellation, Weather, Boarding
        Message NVARCHAR(1000) NOT NULL,
        Severity NVARCHAR(20) DEFAULT 'Info', -- Info, Warning, Critical
        IsResolved BIT DEFAULT 0,
        CreatedAt DATETIME DEFAULT GETDATE(),
        CreatedBy INT,
        ResolvedAt DATETIME,
        ResolvedBy INT,
        CONSTRAINT FK_FlightNotifications_Flights FOREIGN KEY (FlightId) REFERENCES Flights(FlightId) ON DELETE CASCADE,
        CONSTRAINT FK_FlightNotifications_CreatedBy FOREIGN KEY (CreatedBy) REFERENCES Users(UserId)
    );
END
GO

-- =============================================
-- Table: WeatherAlerts
-- =============================================
IF NOT EXISTS (SELECT * FROM sys.tables WHERE name = 'WeatherAlerts')
BEGIN
    CREATE TABLE WeatherAlerts (
        AlertId INT IDENTITY(1,1) PRIMARY KEY,
        AirportId INT NOT NULL,
        AlertType NVARCHAR(50) NOT NULL, -- Storm, Fog, Snow, Wind, Ice
        Severity NVARCHAR(20) NOT NULL, -- Low, Medium, High, Severe
        Description NVARCHAR(500),
        StartTime DATETIME NOT NULL,
        EndTime DATETIME,
        IsActive BIT DEFAULT 1,
        CreatedAt DATETIME DEFAULT GETDATE(),
        CONSTRAINT FK_WeatherAlerts_Airports FOREIGN KEY (AirportId) REFERENCES Airports(AirportId)
    );
END
GO

-- =============================================
-- Table: GateAssignments
-- =============================================
IF NOT EXISTS (SELECT * FROM sys.tables WHERE name = 'GateAssignments')
BEGIN
    CREATE TABLE GateAssignments (
        AssignmentId INT IDENTITY(1,1) PRIMARY KEY,
        FlightId INT NOT NULL,
        GateNumber NVARCHAR(10) NOT NULL,
        GateType NVARCHAR(20), -- Departure, Arrival
        ScheduledTime DATETIME NOT NULL,
        ActualTime DATETIME,
        Status NVARCHAR(20) DEFAULT 'Assigned', -- Assigned, InUse, Released
        AssignedAt DATETIME DEFAULT GETDATE(),
        AssignedBy INT,
        CONSTRAINT FK_GateAssignments_Flights FOREIGN KEY (FlightId) REFERENCES Flights(FlightId) ON DELETE CASCADE,
        CONSTRAINT FK_GateAssignments_AssignedBy FOREIGN KEY (AssignedBy) REFERENCES Users(UserId)
    );
END
GO

-- =============================================
-- Table: FlightDelayReasons
-- =============================================
IF NOT EXISTS (SELECT * FROM sys.tables WHERE name = 'FlightDelayReasons')
BEGIN
    CREATE TABLE FlightDelayReasons (
        DelayId INT IDENTITY(1,1) PRIMARY KEY,
        FlightId INT NOT NULL,
        DelayType NVARCHAR(50) NOT NULL, -- Weather, Technical, Operational, AirTrafficControl, CrewIssue
        DelayMinutes INT NOT NULL,
        Reason NVARCHAR(500),
        ReportedAt DATETIME DEFAULT GETDATE(),
        ReportedBy INT,
        CONSTRAINT FK_FlightDelayReasons_Flights FOREIGN KEY (FlightId) REFERENCES Flights(FlightId) ON DELETE CASCADE,
        CONSTRAINT FK_FlightDelayReasons_ReportedBy FOREIGN KEY (ReportedBy) REFERENCES Users(UserId)
    );
END
GO

-- =============================================
-- Table: FlightSequenceNumbers (For auto-generation)
-- =============================================
IF NOT EXISTS (SELECT * FROM sys.tables WHERE name = 'FlightSequenceNumbers')
BEGIN
    CREATE TABLE FlightSequenceNumbers (
        SequenceId INT IDENTITY(1,1) PRIMARY KEY,
        Prefix NVARCHAR(10) NOT NULL UNIQUE,
        CurrentNumber INT DEFAULT 1000,
        LastUpdated DATETIME DEFAULT GETDATE()
    );
    
    -- Insert default prefixes
    INSERT INTO FlightSequenceNumbers (Prefix, CurrentNumber) VALUES
    ('AA', 1000),
    ('DL', 2000),
    ('UA', 3000),
    ('WN', 4000);
END
GO

-- =============================================
-- Create Indexes for Performance
-- =============================================
CREATE NONCLUSTERED INDEX IX_RouteLayovers_RouteId ON RouteLayovers(RouteId);
CREATE NONCLUSTERED INDEX IX_FlightScheduleTemplates_RouteId ON FlightScheduleTemplates(RouteId);
CREATE NONCLUSTERED INDEX IX_FlightScheduleTemplates_RecurrenceType ON FlightScheduleTemplates(RecurrenceType);
CREATE NONCLUSTERED INDEX IX_FlightNotifications_FlightId ON FlightNotifications(FlightId);
CREATE NONCLUSTERED INDEX IX_FlightNotifications_NotificationType ON FlightNotifications(NotificationType);
CREATE NONCLUSTERED INDEX IX_WeatherAlerts_AirportId ON WeatherAlerts(AirportId);
CREATE NONCLUSTERED INDEX IX_WeatherAlerts_IsActive ON WeatherAlerts(IsActive);
CREATE NONCLUSTERED INDEX IX_GateAssignments_FlightId ON GateAssignments(FlightId);
CREATE NONCLUSTERED INDEX IX_GateAssignments_Status ON GateAssignments(Status);
CREATE NONCLUSTERED INDEX IX_FlightDelayReasons_FlightId ON FlightDelayReasons(FlightId);
GO

-- =============================================
-- Add columns to existing Flights table
-- =============================================
IF NOT EXISTS (SELECT * FROM sys.columns WHERE object_id = OBJECT_ID('Flights') AND name = 'TemplateId')
BEGIN
    ALTER TABLE Flights ADD TemplateId INT NULL;
    ALTER TABLE Flights ADD CONSTRAINT FK_Flights_Template FOREIGN KEY (TemplateId) REFERENCES FlightScheduleTemplates(TemplateId);
END
GO

IF NOT EXISTS (SELECT * FROM sys.columns WHERE object_id = OBJECT_ID('Flights') AND name = 'DelayMinutes')
BEGIN
    ALTER TABLE Flights ADD DelayMinutes INT DEFAULT 0;
END
GO

IF NOT EXISTS (SELECT * FROM sys.columns WHERE object_id = OBJECT_ID('Flights') AND name = 'BoardingStatus')
BEGIN
    ALTER TABLE Flights ADD BoardingStatus NVARCHAR(50) DEFAULT 'NotStarted'; -- NotStarted, Boarding, Completed, Closed
END
GO

