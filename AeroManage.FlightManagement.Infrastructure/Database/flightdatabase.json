CREATE TABLE Airport (
    AirportId INT IDENTITY(1,1) PRIMARY KEY,
    AirportCode VARCHAR(10) NOT NULL,
    ICAOCode VARCHAR(10),
    AirportName VARCHAR(200),
    City VARCHAR(100),
    State VARCHAR(100),
    Country VARCHAR(100),
    Latitude DECIMAL(10,6),
    Longitude DECIMAL(10,6),
    Timezone VARCHAR(100),
    IsActive BIT DEFAULT 1,
    CreatedAt DATETIME DEFAULT GETDATE(),
    UpdatedAt DATETIME DEFAULT GETDATE(),
    TotalRecords INT
);



CREATE TABLE Route (
    RouteId INT IDENTITY(1,1) PRIMARY KEY,
    RouteCode VARCHAR(50),

    OriginAirportId INT NOT NULL,
    DestinationAirportId INT NOT NULL,

    Distance INT,
    EstimatedDuration INT,

    TotalRecords INT,

    CONSTRAINT FK_Route_OriginAirport
    FOREIGN KEY (OriginAirportId)
    REFERENCES Airport(AirportId),

    CONSTRAINT FK_Route_DestinationAirport
    FOREIGN KEY (DestinationAirportId)
    REFERENCES Airport(AirportId)
);



CREATE TABLE Aircraft (
    AircraftId INT IDENTITY(1,1) PRIMARY KEY,
    RegistrationNumber VARCHAR(50),
    AircraftType VARCHAR(50),
    Manufacturer VARCHAR(100),
    Model VARCHAR(100),
    YearManufactured INT,

    TotalSeats INT,
    EconomySeats INT,
    BusinessSeats INT,
    FirstClassSeats INT,

    CurrentStatus VARCHAR(50),

    LastMaintenanceDate DATETIME,
    NextMaintenanceDate DATETIME,

    IsActive BIT DEFAULT 1,

    CreatedAt DATETIME DEFAULT GETDATE(),
    UpdatedAt DATETIME DEFAULT GETDATE(),

    TotalRecords INT
);





CREATE TABLE Flight (
    FlightId INT IDENTITY(1,1) PRIMARY KEY,
    FlightNumber VARCHAR(50),

    RouteId INT NOT NULL,
    AircraftId INT NOT NULL,

    DepartureDateTime DATETIME,
    ArrivalDateTime DATETIME,

    ActualDepartureDateTime DATETIME NULL,
    ActualArrivalDateTime DATETIME NULL,

    FlightStatus VARCHAR(50),

    CreatedBy INT,
    CreatedAt DATETIME DEFAULT GETDATE(),
    UpdatedAt DATETIME DEFAULT GETDATE(),

    TotalRecords INT,

    CONSTRAINT FK_Flight_Route
    FOREIGN KEY (RouteId)
    REFERENCES Route(RouteId),

    CONSTRAINT FK_Flight_Aircraft
    FOREIGN KEY (AircraftId)
    REFERENCES Aircraft(AircraftId)
);





CREATE TABLE FlightPrice (
    Id INT IDENTITY(1,1) PRIMARY KEY,

    FlightId INT NOT NULL,

    ClassType VARCHAR(50), -- Economy, Business, First

    Price DECIMAL(10,2),

    CONSTRAINT FK_FlightPrice_Flight
    FOREIGN KEY (FlightId)
    REFERENCES Flight(FlightId)
);




CREATE TABLE FlightSeatAvailability (
    Id INT IDENTITY(1,1) PRIMARY KEY,

    FlightId INT NOT NULL,

    ClassType VARCHAR(50),

    AvailableSeats INT,

    CONSTRAINT FK_FlightSeatAvailability_Flight
    FOREIGN KEY (FlightId)
    REFERENCES Flight(FlightId)
);




CREATE TABLE GateAssignment (
    AssignmentId INT IDENTITY(1,1) PRIMARY KEY,

    FlightId INT NOT NULL,

    GateNumber VARCHAR(20),

    GateType VARCHAR(20), -- Departure / Arrival

    ScheduledTime DATETIME,

    ActualTime DATETIME NULL,

    Status VARCHAR(50), -- Assigned, InUse, Released

    AssignedAt DATETIME DEFAULT GETDATE(),

    AssignedBy INT,

    CONSTRAINT FK_GateAssignment_Flight
    FOREIGN KEY (FlightId)
    REFERENCES Flight(FlightId)
);











