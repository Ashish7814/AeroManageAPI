  CREATE PROCEDURE sp_InsertMaintenanceRecord
    @AircraftId INT,
    @DatePerformed DATETIME,
    @PerformedBy NVARCHAR(100),
    @Description NVARCHAR(MAX),
    @NextDueDate DATETIME
AS
BEGIN
    INSERT INTO MaintenanceRecord
    (AircraftId, DatePerformed, PerformedBy, Description, NextDueDate)
    VALUES
    (@AircraftId, @DatePerformed, @PerformedBy, @Description, @NextDueDate);

    SELECT SCOPE_IDENTITY() AS MaintenanceRecordId;
END




  CREATE PROCEDURE sp_UpdateMaintenanceRecord
    @MaintenanceRecordId INT,
    @DatePerformed DATETIME,
    @PerformedBy NVARCHAR(100),
    @Description NVARCHAR(MAX),
    @NextDueDate DATETIME
AS
BEGIN
    UPDATE MaintenanceRecord
    SET
        DatePerformed = @DatePerformed,
        PerformedBy = @PerformedBy,
        Description = @Description,
        NextDueDate = @NextDueDate
    WHERE MaintenanceRecordId = @MaintenanceRecordId;
END




  CREATE PROCEDURE sp_DeleteMaintenanceRecord
    @MaintenanceRecordId INT
AS
BEGIN
    DELETE FROM MaintenanceRecord
    WHERE MaintenanceRecordId = @MaintenanceRecordId;
END




  CREATE PROCEDURE sp_GetMaintenanceRecordsByAircraft
    @AircraftId INT
AS
BEGIN
    SELECT *
    FROM MaintenanceRecord
    WHERE AircraftId = @AircraftId
    ORDER BY DatePerformed DESC;
END





CREATE PROCEDURE GetAirports
    @PageNumber INT = 1,
    @PageSize INT = 10
AS
BEGIN
    SET NOCOUNT ON;

    -- 📊 Total Records
    DECLARE @TotalRecords INT;

    SELECT @TotalRecords = COUNT(*) 
    FROM Airports
    WHERE IsActive = 1;

    -- ✈️ Paged Data
    SELECT 
        AirportId,
        AirportCode,
        ICAOCode,
        AirportName,
        City,
        State,
        Country,
        Latitude,
        Longitude,
        Timezone,
        IsActive,
        CreatedAt,
        UpdatedAt,
        @TotalRecords AS TotalRecords
    FROM Airports
    WHERE IsActive = 1
    ORDER BY CreatedAt DESC
    OFFSET (@PageNumber - 1) * @PageSize ROWS
    FETCH NEXT @PageSize ROWS ONLY;
END









