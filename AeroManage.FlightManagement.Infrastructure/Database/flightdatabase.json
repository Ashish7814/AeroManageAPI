  CREATE PROCEDURE sp_GetFlightStatusHistory
    @FlightId INT
AS
BEGIN
    SET NOCOUNT ON;

    SELECT 
        fsh.StatusHistoryId,
        fsh.FlightId,
        fsh.OldStatus,
        fsh.NewStatus,
        fsh.Reason,
        u.UserId AS ChangedById,
        u.FirstName AS ChangedByFirstName,
        u.LastName AS ChangedByLastName,
        u.Email AS ChangedByEmail,
        fsh.ChangedAt
    FROM FlightStatusHistory fsh
    INNER JOIN Users u ON fsh.ChangedBy = u.UserId
    WHERE fsh.FlightId = @FlightId
    ORDER BY fsh.ChangedAt DESC;
END;





  CREATE TABLE FlightNotifications
(
    NotificationId INT IDENTITY(1,1) PRIMARY KEY,

    FlightId INT NOT NULL,

    NotificationType NVARCHAR(50) NOT NULL, 
    -- Delay, GateChange, Cancellation, Weather, Boarding

    Message NVARCHAR(500) NOT NULL,

    Severity NVARCHAR(20) NOT NULL, 
    -- Info, Warning, Critical

    IsResolved BIT NOT NULL DEFAULT 0,

    CreatedAt DATETIME2 NOT NULL DEFAULT GETUTCDATE(),

    ChangedByUserId INT NULL,   -- FK to Users

    ResolvedAt DATETIME2 NULL,

    CONSTRAINT FK_FlightNotifications_Users
        FOREIGN KEY (ChangedByUserId)
        REFERENCES Users(UserId)
);




