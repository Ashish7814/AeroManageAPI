CREATE PROCEDURE sp_GetFlightDelayHistory
(
    @FlightId INT
)
AS
BEGIN

    SELECT
        d.DelayId,
        d.FlightId,
        d.DelayType,
        d.DelayMinutes,
        d.Reason,
        d.ReportedAt,

        u.UserId,
        u.FirstName,
        u.LastName,
        u.Email,
        u.PhoneNumber,

        r.RoleId,
        r.RoleName

    FROM FlightDelayReasons d

    LEFT JOIN Users u
        ON d.ReportedByUserId = u.UserId

    LEFT JOIN Roles r
        ON u.RoleId = r.RoleId

    WHERE d.FlightId = @FlightId

    ORDER BY d.ReportedAt DESC

END




  CREATE PROCEDURE sp_UpdateAircraft
    @AircraftId INT,
    @RegistrationNumber NVARCHAR(50),
    @AircraftType NVARCHAR(50),
    @Manufacturer NVARCHAR(50),
    @Model NVARCHAR(50),
    @YearManufactured INT,
    @EconomySeats INT,
    @BusinessSeats INT,
    @FirstClassSeats INT,
    @CurrentStatus INT,
    @LastMaintenanceDate DATETIME,
    @NextMaintenanceDate DATETIME,
    @IsActive BIT,
    @CurrentLocation NVARCHAR(100)
AS
BEGIN
    UPDATE Aircraft
    SET 
        RegistrationNumber = @RegistrationNumber,
        AircraftType = @AircraftType,
        Manufacturer = @Manufacturer,
        Model = @Model,
        YearManufactured = @YearManufactured,
        EconomySeats = @EconomySeats,
        BusinessSeats = @BusinessSeats,
        FirstClassSeats = @FirstClassSeats,
        CurrentStatus = @CurrentStatus,
        LastMaintenanceDate = @LastMaintenanceDate,
        NextMaintenanceDate = @NextMaintenanceDate,
        IsActive = @IsActive,
        CurrentLocation = @CurrentLocation,
        UpdatedAt = GETDATE()
    WHERE AircraftId = @AircraftId;
END





CREATE PROCEDURE sp_InsertAircraft
    @RegistrationNumber NVARCHAR(50),
    @AircraftType NVARCHAR(50),
    @Manufacturer NVARCHAR(50),
    @Model NVARCHAR(50),
    @YearManufactured INT,
    @EconomySeats INT,
    @BusinessSeats INT,
    @FirstClassSeats INT,
    @CurrentStatus INT, -- map to AircraftStatus enum
    @LastMaintenanceDate DATETIME,
    @NextMaintenanceDate DATETIME,
    @IsActive BIT,
    @CurrentLocation NVARCHAR(100)
AS
BEGIN
    INSERT INTO Aircraft 
    (RegistrationNumber, AircraftType, Manufacturer, Model, YearManufactured, EconomySeats, BusinessSeats, FirstClassSeats, CurrentStatus, LastMaintenanceDate, NextMaintenanceDate, IsActive, CurrentLocation, CreatedAt, UpdatedAt)
    VALUES 
    (@RegistrationNumber, @AircraftType, @Manufacturer, @Model, @YearManufactured, @EconomySeats, @BusinessSeats, @FirstClassSeats, @CurrentStatus, @LastMaintenanceDate, @NextMaintenanceDate, @IsActive, @CurrentLocation, GETDATE(), GETDATE());
    
    SELECT SCOPE_IDENTITY() AS AircraftId; -- returns newly inserted AircraftId
END



