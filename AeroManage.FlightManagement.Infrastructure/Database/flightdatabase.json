CREATE PROCEDURE sp_GetFlights
AS
BEGIN
    SET NOCOUNT ON;

    ------------------------------------------------
    -- 1️⃣ Flights + Route + Aircraft + Airports
    ------------------------------------------------

    SELECT
        f.FlightId,
        f.FlightNumber,
        f.RouteId,
        f.AircraftId,
        f.DepartureDateTime,
        f.ArrivalDateTime,
        f.ActualDepartureDateTime,
        f.ActualArrivalDateTime,
        f.FlightStatus,
        f.CreatedBy,
        f.CreatedAt,
        f.UpdatedAt,

        r.RouteId,
        r.RouteCode,
        r.OriginAirportId,
        r.DestinationAirportId,
        r.Distance,
        r.EstimatedDuration,
        r.TotalRecords,

        oa.AirportId AS OriginAirportId,
        oa.AirportCode AS OriginAirportCode,
        oa.AirportName AS OriginAirportName,
        oa.City AS OriginCity,
        oa.State AS OriginState,
        oa.Country AS OriginCountry,
        oa.Latitude AS OriginLatitude,
        oa.Longitude AS OriginLongitude,
        oa.Timezone AS OriginTimezone,
        oa.IsActive AS OriginIsActive,

        da.AirportId AS DestinationAirportId,
        da.AirportCode AS DestinationAirportCode,
        da.AirportName AS DestinationAirportName,
        da.City AS DestinationCity,
        da.State AS DestinationState,
        da.Country AS DestinationCountry,
        da.Latitude AS DestinationLatitude,
        da.Longitude AS DestinationLongitude,
        da.Timezone AS DestinationTimezone,
        da.IsActive AS DestinationIsActive,

        a.AircraftId,
        a.RegistrationNumber,
        a.AircraftType,
        a.Manufacturer,
        a.Model,
        a.YearManufactured,
        a.TotalSeats,
        a.EconomySeats,
        a.BusinessSeats,
        a.FirstClassSeats,
        a.CurrentStatus,
        a.LastMaintenanceDate,
        a.NextMaintenanceDate,
        a.IsActive

    FROM Flight f

    INNER JOIN Route r
        ON f.RouteId = r.RouteId

    INNER JOIN Airport oa
        ON r.OriginAirportId = oa.AirportId

    INNER JOIN Airport da
        ON r.DestinationAirportId = da.AirportId

    INNER JOIN Aircraft a
        ON f.AircraftId = a.AircraftId;


    ------------------------------------------------
    -- 2️⃣ Flight Prices
    ------------------------------------------------

    SELECT
        Id,
        FlightId,
        ClassType,
        Price
    FROM FlightPrice;


    ------------------------------------------------
    -- 3️⃣ Seat Availability
    ------------------------------------------------

    SELECT
        Id,
        FlightId,
        ClassType,
        AvailableSeats
    FROM FlightSeatAvailability;


    ------------------------------------------------
    -- 4️⃣ Gate Assignments
    ------------------------------------------------

    SELECT
        AssignmentId,
        FlightId,
        GateNumber,
        GateType,
        ScheduledTime,
        ActualTime,
        Status
    FROM GateAssignment;

END




CREATE PROCEDURE sp_CreateFlight
(
    @FlightNumber VARCHAR(50),
    @RouteId INT,
    @AircraftId INT,
    @DepartureDateTime DATETIME,
    @ArrivalDateTime DATETIME,
    @FlightStatus VARCHAR(50),
    @CreatedBy INT
)
AS
BEGIN

INSERT INTO Flight
(
FlightNumber,
RouteId,
AircraftId,
DepartureDateTime,
ArrivalDateTime,
FlightStatus,
CreatedBy,
CreatedAt,
UpdatedAt
)

VALUES
(
@FlightNumber,
@RouteId,
@AircraftId,
@DepartureDateTime,
@ArrivalDateTime,
@FlightStatus,
@CreatedBy,
GETDATE(),
GETDATE()
)

SELECT SCOPE_IDENTITY() AS FlightId

END





CREATE PROCEDURE sp_UpdateFlightStatus
(
    @FlightId INT,
    @FlightStatus VARCHAR(50)
)
AS
BEGIN

UPDATE Flight
SET
FlightStatus = @FlightStatus,
UpdatedAt = GETDATE()

WHERE FlightId = @FlightId

END






