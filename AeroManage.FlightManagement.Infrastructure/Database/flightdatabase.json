CREATE PROCEDURE sp_GetFlightNotifications
(
    @FlightId INT,
    @IncludeResolved BIT
)
AS
BEGIN

    SELECT
        fn.NotificationId,
        fn.FlightId,
        fn.NotificationType,
        fn.Message,
        fn.Severity,
        fn.IsResolved,
        fn.CreatedAt,
        fn.ResolvedAt,

        u.UserId,
        u.FirstName,
        u.LastName,
        u.Email,
        u.PhoneNumber

    FROM FlightNotifications fn

    LEFT JOIN Users u
        ON fn.ChangedByUserId = u.UserId

    WHERE fn.FlightId = @FlightId
      AND (
            @IncludeResolved = 1
            OR fn.IsResolved = 0
          )

    ORDER BY fn.CreatedAt DESC;

END



