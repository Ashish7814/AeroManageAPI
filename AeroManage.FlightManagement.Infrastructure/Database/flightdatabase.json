CREATE PROCEDURE sp_GetFlightCrew
    @FlightId INT
AS
BEGIN

    SELECT
        fc.FlightCrewId,
        fc.FlightId,
        fc.UserId,
        fc.AssignedAt,

        u.FirstName,
        u.LastName,
        u.Email,
        u.PhoneNumber,

        r.RoleId,
        r.RoleName

    FROM FlightCrew fc

    INNER JOIN Users u
        ON fc.UserId = u.UserId

    INNER JOIN Roles r
        ON u.RoleId = r.RoleId

    WHERE fc.FlightId = @FlightId

END




